@model RapChieuPhim.Models.Entities.DonHang

@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-success text-white text-center py-4">
                    <i class="bi bi-check-circle-fill display-4"></i>
                    <h3 class="fw-bold mt-2">THANH TOÁN THÀNH CÔNG</h3>
                    <p class="mb-0 small">Cảm ơn bạn đã tin dùng dịch vụ của B E T A Cinemas</p>
                </div>

                <div class="card-body p-5 bg-white">
                    <div class="text-center mb-4">
                        <p class="text-muted mb-1">Mã giao dịch: <span class="fw-bold text-dark">#@Model.MaDonHang</span></p>
                        <p class="small text-success fw-bold"><i class="bi bi-check-circle"></i> Đã thanh toán thành công</p>
                    </div>

                    @if (Model.ChiTietVes != null && Model.ChiTietVes.Any())
                    {
                        var suat = Model.ChiTietVes.First().MaSuatChieuNavigation;
                        <div class="card border-primary mb-4 shadow-sm">
                            <div class="card-header bg-primary text-white fw-bold">
                                <i class="bi bi-ticket-perforated me-2"></i> THÔNG TIN VÉ XEM PHIM
                            </div>
                            <div class="card-body d-flex gap-4 align-items-center">
                                <div class="text-center">
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=@Model.MaDonHang" alt="QR Code" class="border p-1 rounded bg-white mb-2">
                                    <div class="small text-muted">Mã quét vé</div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold text-uppercase text-primary mb-2">@suat?.MaPhimNavigation?.TenPhim</h5>
                                    <p class="mb-1"><i class="bi bi-clock text-muted"></i> Suất chiếu: <strong class="text-dark">@suat?.ThoiGianBatDau.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                                    <p class="mb-1"><i class="bi bi-geo-alt text-muted"></i> Phòng chiếu: <strong class="text-dark">@suat?.MaPhongNavigation?.TenPhong</strong></p>
                                    <p class="mb-0">
                                        <i class="bi bi-ui-checks-grid text-muted"></i> Ghế:
                                        @foreach (var ve in Model.ChiTietVes)
                                        {
                                            <span class="badge bg-danger ms-1 fs-6">@(ve.MaGheNavigation?.TenHang + ve.MaGheNavigation?.SoThu)</span>
                                        }
                                    </p>
                                </div>
                                <div class="text-end border-start ps-3">
                                    <span class="d-block text-muted small">Tiền vé</span>
                                    <strong class="fs-5">@string.Format("{0:#,##0}", Model.ChiTietVes.Sum(v => v.GiaVe))đ</strong>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Model.ChiTietDichVus != null && Model.ChiTietDichVus.Any())
                    {
                        <div class="card border-warning mb-4 shadow-sm">
                            <div class="card-header bg-warning text-dark fw-bold">
                                <i class="bi bi-cup-straw me-2"></i> DỊCH VỤ ẨM THỰC
                            </div>
                            <div class="card-body">
                                @foreach (var item in Model.ChiTietDichVus)
                                {
                                    <div class="d-flex justify-content-between mb-2 border-bottom pb-2">
                                        <span>🍿 @item.MaDichVuNavigation?.TenDichVu <strong class="text-danger ms-2">x @item.SoLuong</strong></span>
                                        <span class="fw-bold">@string.Format("{0:#,##0}", item.DonGia * item.SoLuong)đ</span>
                                    </div>
                                }
                                <div class="text-end mt-2">
                                    <span class="text-muted small">Tổng tiền ẩm thực:</span>
                                    <strong class="fs-5 text-warning ms-2">@string.Format("{0:#,##0}", Model.ChiTietDichVus.Sum(d => d.DonGia * d.SoLuong))đ</strong>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="bg-light p-4 rounded-3 border">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính:</span>
                            <span class="fw-bold">@string.Format("{0:#,##0}", Model.TongTienBanDau)đ</span>
                        </div>
                        @if (Model.MaKhuyenMai != null)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Giảm giá (@Model.MaKhuyenMaiNavigation?.MaCode):</span>
                                <span class="fw-bold">-@string.Format("{0:#,##0}", Model.TongTienBanDau - Model.TongTienSauGiam)đ</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between pt-3 mt-2 border-top align-items-center">
                            <h5 class="fw-bold mb-0">ĐÃ THANH TOÁN:</h5>
                            <h3 class="fw-bold text-danger mb-0">@string.Format("{0:#,##0}", Model.TongTienSauGiam)đ</h3>
                        </div>
                    </div>

                    @if (string.IsNullOrEmpty(Model.MaKhachHang))
                    {
                        <div class="alert alert-warning text-center mt-4 mb-0">
                            <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i> Vui lòng chụp màn hình vé này để soát vé tại rạp!
                        </div>
                    }

                    <div class="text-center mt-4">
                        <a href="/" class="btn btn-outline-secondary px-4 fw-bold">VỀ TRANG CHỦ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>