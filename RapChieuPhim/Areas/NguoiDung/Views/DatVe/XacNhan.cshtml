@{
    ViewData["Title"] = "Xác nhận đặt vé";
    var suatChieu = ViewBag.SuatChieu as RapChieuPhim.Models.Entities.SuatChieu;
    var Ghe = ViewBag.Ghe as List<RapChieuPhim.Models.Entities.Ghe>;
    var menuBapNuoc = ViewBag.MenuBapNuoc as List<RapChieuPhim.Models.Entities.DanhMucDichVu>;
    double tongTienVe = ViewBag.TongTienVe;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <h4 class="fw-bold mb-4" style="color: #034ea2;"><i class="bi bi-ticket-detailed me-2"></i>THÔNG TIN ĐẶT VÉ</h4>

            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4 d-flex gap-4">
                    <img src="@(suatChieu.MaPhimNavigation.DuongDanAnh ?? "/images/default/no-poster.jpg")" class="rounded-3 shadow-sm" style="width: 120px; height: 180px; object-fit: cover;">

                    <div class="flex-grow-1">
                        <h4 class="fw-bold text-uppercase">@suatChieu.MaPhimNavigation.TenPhim</h4>
                        <p class="text-muted mb-2"><i class="bi bi-clock"></i> Suất chiếu: <strong class="text-dark">@suatChieu.ThoiGianBatDau.ToString("HH:mm - dd/MM/yyyy")</strong></p>
                        <p class="text-muted mb-2"><i class="bi bi-geo-alt"></i> Phòng: <strong class="text-dark">@suatChieu.MaPhongNavigation.TenPhong</strong></p>

                        <div class="mt-3 p-3 bg-light rounded-3 border">
                            <span class="text-muted small d-block mb-1">Ghế đã chọn:</span>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var g in Ghe)
                                {
                                    <span class="badge bg-danger fs-6 px-3 py-2">@(g.TenHang + g.SoThu)</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0" style="color: #034ea2;"><i class="bi bi-cup-straw me-2"></i>DỊCH VỤ ĐI KÈM</h5>
                <button class="btn btn-warning fw-bold btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#bapNuocModal">
                    <i class="bi bi-plus-circle me-1"></i> Mua thêm Bắp Nước
                </button>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-3">
                    <ul class="list-group list-group-flush" id="cartBapNuocList">
                        <li class="list-group-item text-center text-muted py-3" id="emptyCartMsg">Chưa có dịch vụ đi kèm.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 border-top border-danger border-5 sticky-top" style="top: 20px;">
                <div class="card-body p-4 text-center">
                    <h6 class="text-muted mb-2">THỜI GIAN GIỮ GHẾ CÒN LẠI</h6>
                    <h1 class="display-3 fw-bold text-danger mb-4" id="countdownTimer" style="font-variant-numeric: tabular-nums;">05:00</h1>

                    <hr>

                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Tiền vé (@Ghe.Count ghế):</span>
                        <strong class="text-dark" id="tienVe">@string.Format("{0:#,##0}", tongTienVe)đ</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3 small text-muted">
                        <span>Tiền bắp nước:</span>
                        <strong class="text-dark" id="tienBapNuoc">0đ</strong>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 pt-3 border-top">
                        <span class="fw-bold fs-5">TỔNG CỘNG</span>
                        <span class="fw-bold fs-3 text-danger" id="tongTienTatCa">@string.Format("{0:#,##0}", tongTienVe)đ</span>
                    </div>

                    <button class="btn btn-lg w-100 fw-bold text-white shadow-sm" style="background-color: #034ea2; border-radius: 12px;" onclick="thanhToanNgay()">
                        TIẾP TỤC THANH TOÁN <i class="bi bi-credit-card ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bapNuocModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold" style="color: #034ea2;"><i class="bi bi-popcorn me-2"></i>CHỌN BẮP NƯỚC</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light p-4">
                @foreach (var dm in menuBapNuoc)
                {
                    <h6 class="fw-bold mb-3 border-bottom pb-2">@dm.TenDanhMuc</h6>
                    <div class="row g-3 mb-4">
                        @foreach (var dv in dm.DichVu)
                        {
                            var imgUrl = string.IsNullOrEmpty(dv.DuongDanHinh) ? "/images/default/no-image.jpg" : dv.DuongDanHinh;
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body d-flex align-items-center p-2">
                                        <img src="@imgUrl" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1 fw-bold text-truncate" style="max-width: 150px;">@dv.TenDichVu</h6>
                                            <span class="text-danger fw-bold small">@string.Format("{0:#,##0}", dv.GiaBan)đ</span>
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger fw-bold rounded-pill px-3" onclick="addPopcorn('@dv.MaDichVu', '@dv.TenDichVu', @dv.GiaBan, '@imgUrl')">
                                            THÊM
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-secondary fw-bold px-4 rounded-pill" data-bs-dismiss="modal">XONG</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tongTienVe = @tongTienVe;
        var tongTienBapNuoc = 0;
        var gioHangBapNuoc = []; // Mảng chứa các món bắp nước

        // Mảng chứa Mã Ghế để đẩy sang Controller
        var maGhe = [
        @foreach (var g in Ghe)
        {
            <text>'@g.MaGhe',</text>
        }
        ];
        var maSuatChieu = '@suatChieu.MaSuatChieu';

        function formatVND(amount) { return amount.toLocaleString('vi-VN') + 'đ'; }

        // 1. LOGIC ĐỒNG HỒ ĐẾM NGƯỢC
        var expireTime = new Date('@ViewBag.ExpireTime').getTime();

        var timer = setInterval(function() {
            var now = new Date().getTime();
            var distance = expireTime - now;

            if (distance < 0) {
                clearInterval(timer);
                $('#countdownTimer').text("00:00");
                Swal.fire({
                    title: 'Đã hết thời gian!',
                    text: 'Phiên giao dịch của bạn đã hết hạn. Hệ thống sẽ quay về trang Chọn Ghế.',
                    icon: 'error',
                    allowOutsideClick: false,
                    confirmButtonText: 'Đồng ý'
                }).then((result) => {
                    window.location.href = '@Url.Action("ChonGhe", "DatVe", new { area = "NguoiDung", maPhim = suatChieu.MaPhim })';
                });
                return;
            }

            var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            var seconds = Math.floor((distance % (1000 * 60)) / 1000);

            $('#countdownTimer').text(
                (minutes < 10 ? "0" + minutes : minutes) + ":" +
                (seconds < 10 ? "0" + seconds : seconds)
            );
        }, 1000);

        // 2. LOGIC GIỎ HÀNG BẮP NƯỚC (Winforms style)
        function addPopcorn(maDV, tenDV, giaBan, hinh) {
            var existingItem = gioHangBapNuoc.find(x => x.MaDichVu === maDV);
            if (existingItem) {
                existingItem.SoLuong += 1;
            } else {
                gioHangBapNuoc.push({
                    MaDichVu: maDV, TenDichVu: tenDV, GiaBan: giaBan, SoLuong: 1, DuongDanHinh: hinh, ThanhTien: giaBan
                });
            }
            renderPopcornCart();

            // Hiệu ứng Toast xịn xò
            const Toast = Swal.mixin({ toast: true, position: 'bottom-end', showConfirmButton: false, timer: 1500 });
            Toast.fire({ icon: 'success', title: 'Đã thêm ' + tenDV });
        }

        function removePopcorn(maDV) {
            var item = gioHangBapNuoc.find(x => x.MaDichVu === maDV);
            if(item) {
                item.SoLuong -= 1;
                if(item.SoLuong <= 0) {
                    gioHangBapNuoc = gioHangBapNuoc.filter(x => x.MaDichVu !== maDV);
                }
            }
            renderPopcornCart();
        }

                function renderPopcornCart() {
            var listEl = $('#cartBapNuocList');
            listEl.empty();
            tongTienBapNuoc = 0;

            if (gioHangBapNuoc.length === 0) {
                listEl.append('<li class="list-group-item text-center text-muted py-3">Chưa có dịch vụ đi kèm.</li>');
            } else {
                $.each(gioHangBapNuoc, function(i, item) {
                    item.ThanhTien = item.GiaBan * item.SoLuong;
                    tongTienBapNuoc += item.ThanhTien;

                    listEl.append(`
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div class="d-flex align-items-center">
                                <img src="${item.DuongDanHinh}" class="rounded me-3 shadow-sm" style="width: 40px; height: 40px; object-fit: cover;">
                                <div>
                                    <h6 class="mb-0 fw-bold">${item.TenDichVu}</h6>
                                    <small class="text-muted">${formatVND(item.GiaBan)}</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="input-group input-group-sm rounded bg-light border" style="width: 90px;">
                                    <button class="btn btn-sm btn-light border-end" onclick="removePopcorn('${item.MaDichVu}')"><i class="bi bi-dash"></i></button>
                                    <input type="text" class="form-control text-center bg-white border-0 fw-bold px-0" value="${item.SoLuong}" readonly>
                                    <button class="btn btn-sm btn-light border-start" onclick="addPopcorn('${item.MaDichVu}', '${item.TenDichVu}', ${item.GiaBan}, '${item.DuongDanHinh}')"><i class="bi bi-plus"></i></button>
                                </div>
                                <strong class="text-danger" style="width: 80px; text-align: right;">${formatVND(item.ThanhTien)}</strong>
                            </div>
                        </li>
                    `);
                });
            }

            // Cập nhật Cột phải
            $('#tienBapNuoc').text(formatVND(tongTienBapNuoc));
            $('#tongTienTatCa').text(formatVND(tongTienVe + tongTienBapNuoc));

            // GỌI AJAX ĐỒNG BỘ SESSION (Lưu nháp bắp nước trên server)
            $.ajax({
                url: '/NguoiDung/DatVe/SyncBapNuocTam',
                type: 'POST',
                data: { jsonBapNuoc: JSON.stringify(gioHangBapNuoc) }
            });
        }

        // 3. GỬI DATA SANG THANH TOÁN
        function thanhToanNgay() {
            Swal.fire({
                title: 'Đang xử lý...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.ajax({
                url: '@Url.Action("LuuSessionThanhToan", "DatVe", new { area = "NguoiDung" })',
                type: 'POST',
                data: {
                    maSuatChieu: maSuatChieu,
                    maGhe: maGhe,
                    jsonBapNuoc: JSON.stringify(gioHangBapNuoc)
                },
                success: function (res) {
                    if(res.success) {
                        window.location.href = res.redirectUrl;
                    }
                }
            });
        }
    </script>
}