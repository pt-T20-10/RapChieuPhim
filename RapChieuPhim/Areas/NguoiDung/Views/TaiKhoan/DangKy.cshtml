@model RapChieuPhim.Models.ViewModels.DangKyViewModel
@{
    ViewData["Title"] = "Dang ky";
}

<style>
    .beta-blue-bg {
        background-color: #034ea2;
        color: white;
        border: none;
    }

        .beta-blue-bg:hover {
            background-color: #023670;
            color: white;
        }

    .beta-blue-text {
        color: #034ea2;
        text-decoration: none;
        font-weight: 600;
    }

        .beta-blue-text:hover {
            color: #023670;
            text-decoration: underline;
        }

    .form-floating:focus-within label {
        color: #034ea2;
        font-weight: bold;
    }

    .form-control:focus {
        border-color: #034ea2;
        box-shadow: 0 0 0 0.25rem rgba(3,78,162,.25);
    }

    .strength-bar {
        height: 5px;
        border-radius: 3px;
        margin-top: 6px;
        background: #e5e7eb;
    }

    .strength-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width .3s, background .3s;
    }

    .strength-text {
        font-size: .75rem;
        font-weight: 700;
        margin-top: 4px;
        min-height: 18px;
    }

    .pw-req {
        font-size: .78rem;
        display: flex;
        align-items: center;
        gap: 5px;
        color: #9ca3af;
    }

        .pw-req.ok {
            color: #16a34a;
        }

        .pw-req.bad {
            color: #dc2626;
        }

    .or-sep {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 16px 0;
        color: #9ca3af;
        font-size: .8rem;
        font-weight: 700;
    }

        .or-sep::before, .or-sep::after {
            content: '';
            flex: 1;
            border-top: 1px solid #e5e7eb;
        }

    .btn-google {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 11px;
        border: 1.5px solid #e5e7eb;
        border-radius: 50px;
        background: #fff;
        color: #374151;
        font-weight: 700;
        text-decoration: none;
    }

        .btn-google:hover {
            background: #f9fafb;
            color: #111;
        }
</style>

<div class="container py-5" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="row w-100 justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header bg-white text-center py-4 border-0">
                    <h3 class="fw-bold mb-0" style="color: #034ea2;">DANG KY</h3>
                    <p class="text-muted small mt-2 mb-0">Tao tai khoan de dat ve phim</p>
                </div>

                <div class="card-body px-4 pb-4 pt-2">

                    @if (TempData["GoogleError"] != null)
                    {
                        <div class="alert alert-danger small py-2">@TempData["GoogleError"]</div>
                    }

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger small py-2">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="GoogleLogin1"
                       class="btn-google mb-3">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        </svg>
                        Đăng ký với Google
                    </a>

                    <div class="or-sep">HOAC DANG KY BANG EMAIL</div>

                    <form asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="DangKy"
                          method="post" id="formDangKy" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input asp-for="HoTen" class="form-control" placeholder="a" />
                            <label asp-for="HoTen">Ho va ten</label>
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="a" />
                            <label asp-for="Email">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="TenDangNhap" class="form-control" placeholder="a" />
                            <label asp-for="TenDangNhap">Ten dang nhap</label>
                            <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-1">
                            <input asp-for="MatKhau" type="password" class="form-control"
                                   placeholder="a" id="inputMatKhau"
                                   oninput="checkStrength(this.value)" />
                            <label asp-for="MatKhau">Mat khau</label>
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>

                        <div class="mb-1 px-1">
                            <div class="strength-bar">
                                <div class="strength-bar-fill" id="strengthFill" style="width:0%"></div>
                            </div>
                            <div class="strength-text" id="strengthText"></div>
                        </div>

                        <div class="mb-3 px-1" id="pwReqs" style="display:none;">
                            <div class="pw-req" id="req-len"><span>&#9679;</span> It nhat 8 ky tu</div>
                            <div class="pw-req" id="req-upper"><span>&#9679;</span> Co chu hoa (A-Z)</div>
                            <div class="pw-req" id="req-lower"><span>&#9679;</span> Co chu thuong (a-z)</div>
                            <div class="pw-req" id="req-num"><span>&#9679;</span> Co chu so (0-9)</div>
                            <div class="pw-req" id="req-spec"><span>&#9679;</span> Co ky tu dac biet</div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="XacNhanMatKhau" type="password" class="form-control"
                                   placeholder="a" id="inputXacNhan" />
                            <label asp-for="XacNhanMatKhau">Xac nhan mat khau</label>
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small" id="xacNhanErr"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="showPass" onclick="togglePw()">
                            <label class="form-check-label small text-muted" for="showPass">Hien mat khau</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn beta-blue-bg btn-lg fw-bold py-3">
                                DANG KY
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-3 border-0">
                    <span class="text-muted small">Da co tai khoan?</span>
                    <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="DangNhap"
                       class="beta-blue-text small ms-1">Dang nhap ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePw() {
            var t = document.getElementById('showPass').checked ? 'text' : 'password';
            document.getElementById('inputMatKhau').type = t;
            document.getElementById('inputXacNhan').type = t;
        }

        function checkStrength(pw) {
            var fill = document.getElementById('strengthFill');
            var text = document.getElementById('strengthText');
            document.getElementById('pwReqs').style.display = pw.length > 0 ? 'block' : 'none';

            var ok = {
                len:   pw.length >= 8,
                upper: /[A-Z]/.test(pw),
                lower: /[a-z]/.test(pw),
                num:   /[0-9]/.test(pw),
                spec:  /[^A-Za-z0-9]/.test(pw)
            };

            ['len','upper','lower','num','spec'].forEach(function(k) {
                var el = document.getElementById('req-' + k);
                el.classList.toggle('ok',  ok[k]);
                el.classList.toggle('bad', !ok[k] && pw.length > 0);
            });

            var score = Object.values(ok).filter(Boolean).length;
            var cfg = [
                {pct:'0%',   bg:'#e5e7eb', lbl:'',          cls:''},
                {pct:'20%',  bg:'#ef4444', lbl:'Rat yeu',    cls:'text-danger'},
                {pct:'40%',  bg:'#f97316', lbl:'Yeu',        cls:'text-warning'},
                {pct:'60%',  bg:'#eab308', lbl:'Trung binh', cls:'text-warning'},
                {pct:'80%',  bg:'#22c55e', lbl:'Manh',       cls:'text-success'},
                {pct:'100%', bg:'#16a34a', lbl:'Rat manh',   cls:'text-success'}
            ][score];

            fill.style.width      = cfg.pct;
            fill.style.background = cfg.bg;
            text.textContent      = cfg.lbl;
            text.className        = 'strength-text fw-bold ' + cfg.cls;
        }

        document.getElementById('inputXacNhan').addEventListener('input', function() {
            var err = document.getElementById('xacNhanErr');
            var pw  = document.getElementById('inputMatKhau').value;
            err.textContent = (this.value && this.value !== pw) ? 'Mat khau khong khop.' : '';
        });

        document.getElementById('formDangKy').addEventListener('submit', function(e) {
            var pw  = document.getElementById('inputMatKhau').value;
            var xn  = document.getElementById('inputXacNhan').value;
            var err = document.getElementById('xacNhanErr');

            if (pw !== xn) {
                err.textContent = 'Mat khau khong khop.';
                e.preventDefault();
                return;
            }

            var ok = pw.length >= 8
                  && /[A-Z]/.test(pw)
                  && /[a-z]/.test(pw)
                  && /[0-9]/.test(pw)
                  && /[^A-Za-z0-9]/.test(pw);

            if (!ok) {
                document.getElementById('strengthText').textContent = 'Mat khau chua du manh';
                document.getElementById('strengthText').className   = 'strength-text fw-bold text-danger';
                document.getElementById('pwReqs').style.display     = 'block';
                e.preventDefault();
            }
        });
    </script>
}
