@model RapChieuPhim.Models.ViewModels.DangNhapViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
    }

    .beta-blue-bg {
        background-color: #034ea2;
        color: white;
        border: none;
        transition: 0.3s;
    }

        .beta-blue-bg:hover {
            background-color: #023670;
            color: white;
            transform: translateY(-2px);
        }

    .beta-blue-text {
        color: #034ea2;
        text-decoration: none;
        font-weight: 600;
    }

        .beta-blue-text:hover {
            color: #023670;
            text-decoration: underline;
        }

    .form-floating:focus-within label {
        color: #034ea2;
        font-weight: bold;
    }

    .form-control:focus {
        border-color: #034ea2;
        box-shadow: 0 0 0 0.25rem rgba(3, 78, 162, 0.25);
    }
</style>

<div class="container login-container py-5">
    <div class="row w-100 justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white text-center py-4 border-0">
                    <h3 class="fw-bold mb-0" style="color: #034ea2;">ĐĂNG NHẬP</h3>
                    <p class="text-muted small mt-2 mb-0">Chào mừng bạn quay lại với Rạp chiếu phim Nhóm 1</p>
                </div>
                <div class="card-body px-4 pb-4 pt-2">

                    @if (TempData["XacMinhSuccess"] != null)
                    {
                        <div class="alert alert-success px-3 py-2 rounded-3 border-0 small">
                            <i class="bi bi-check-circle-fill me-1"></i> @TempData["XacMinhSuccess"]
                        </div>
                    }
                    @if (TempData["XacMinhError"] != null)
                    {
                        <div class="alert alert-danger px-3 py-2 rounded-3 border-0 bg-danger bg-opacity-10 text-danger small">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["XacMinhError"]
                        </div>
                    }
                    @if (TempData["GoogleSuccess"] != null)
                    {
                        <div class="alert alert-success px-3 py-2 rounded-3 border-0 small">
                            <i class="bi bi-google me-1"></i> @TempData["GoogleSuccess"]
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger px-3 py-2 rounded-3 border-0 bg-danger bg-opacity-10 text-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div asp-validation-summary="All" class="d-inline-block small mb-0"></div>
                        </div>
                    }

                    <form asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="DangNhap" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input asp-for="TenDangNhap" class="form-control" placeholder="Email / Tên đăng nhập" autofocus required />
                            <label asp-for="TenDangNhap"><i class="bi bi-person me-2"></i>Email / Tên đăng nhập</label>
                            <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="MatKhau" class="form-control" placeholder="Mật khẩu" id="floatingPassword" required />
                            <label asp-for="MatKhau"><i class="bi bi-lock me-2"></i>Mật khẩu</label>
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" onclick="togglePassword()" id="showPass">
                                <label class="form-check-label small text-muted user-select-none" for="showPass">
                                    Hiện mật khẩu
                                </label>
                            </div>
                            <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="QuenMatKhau" class="small beta-blue-text">Quên mật khẩu?</a>
                        </div>

                        <div class="d-grid gap-3 mb-4">
                            <button type="submit" class="btn beta-blue-bg btn-lg fw-bold py-3 shadow-sm">
                                ĐĂNG NHẬP <i class="bi bi-box-arrow-in-right ms-2"></i>
                            </button>
                        </div>
                    </form>

                    <div class="position-relative text-center my-4">
                        <hr class="text-muted">
                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 small text-muted fw-bold">HOẶC ĐĂNG NHẬP BẰNG</span>
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="GoogleLogin" class="btn btn-outline-danger fw-bold py-2">
                            <i class="bi bi-google me-2"></i> Đăng nhập với Google
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light text-center py-3 border-0">
                    <span class="text-muted small">Chưa có tài khoản?</span>
                    <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="DangKy" class="beta-blue-text small ms-1">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword() {
            var x = document.getElementById("floatingPassword");
            x.type = x.type === "password" ? "text" : "password";
        }
    </script>
}