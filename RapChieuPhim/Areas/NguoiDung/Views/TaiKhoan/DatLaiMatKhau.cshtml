@model RapChieuPhim.Models.ViewModels.DatLaiMatKhauViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-key text-warning" style="font-size: 3rem;"></i>
                        <h4 class="fw-bold mt-2" style="color: #034ea2;">ĐẶT LẠI MẬT KHẨU</h4>
                        <p class="text-muted small">Mã OTP hợp lệ. Vui lòng tạo mật khẩu mới cho tài khoản của bạn.</p>
                    </div>

                    <form asp-action="DatLaiMatKhau" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="MatKhauMoi" type="password" class="form-control" placeholder="Mật khẩu mới" />
                            <label asp-for="MatKhauMoi"><i class="bi bi-lock me-2"></i>Mật khẩu mới</label>
                            <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="XacNhanMatKhau" type="password" class="form-control" placeholder="Xác nhận mật khẩu" />
                            <label asp-for="XacNhanMatKhau"><i class="bi bi-check-circle me-2"></i>Xác nhận mật khẩu</label>
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">Mã bảo mật (Captcha)</label>
                            <div class="d-flex align-items-center gap-3">
                                <img src="/api/captcha" alt="Captcha" class="border rounded" style="cursor: pointer; height: 45px;" onclick="this.src='/api/captcha?t=' + new Date().getTime()" title="Bấm để đổi mã khác" />
                                <input asp-for="CaptchaCode" class="form-control" placeholder="Nhập mã bên cạnh" autocomplete="off" style="height: 45px;" />
                            </div>
                            <span asp-validation-for="CaptchaCode" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn w-100 fw-bold py-3 text-white" style="background-color: #034ea2; border-radius: 50px;">
                            CẬP NHẬT MẬT KHẨU <i class="bi bi-arrow-right-circle ms-1"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}