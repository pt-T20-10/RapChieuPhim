@{
    ViewData["Title"] = "Xác nhận OTP";
    // Lấy Email từ Session để hiển thị cho khách hàng biết mail nào vừa được gửi
    var email = Context.Session.GetString("ResetEmail") ?? "email của bạn";
}

<div class="container py-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <i class="bi bi-envelope-check text-success mb-3" style="font-size: 3.5rem;"></i>
                    <h4 class="fw-bold" style="color: #034ea2;">XÁC NHẬN MÃ OTP</h4>
                    <p class="text-muted small mb-4">
                        Chúng tôi vừa gửi một mã OTP gồm 6 chữ số đến email <br />
                        <strong class="text-dark">@email</strong>.
                    </p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-3 small py-2"><i class="bi bi-x-circle-fill me-1"></i> @ViewBag.Error</div>
                    }

                    <form asp-action="XacNhanOTP" method="post">
                        <div class="form-floating mb-4">
                            <input type="text" class="form-control text-center fw-bold fs-4" id="otpCode" name="otpCode" placeholder="Nhập mã 6 số" maxlength="6" autocomplete="off" required style="letter-spacing: 5px;">
                            <label for="otpCode">Nhập mã OTP tại đây</label>
                        </div>

                        <button type="submit" class="btn w-100 fw-bold py-3 text-white" style="background-color: #034ea2; border-radius: 50px;">
                            XÁC NHẬN <i class="bi bi-check2-circle ms-1"></i>
                        </button>
                    </form>

                    <div class="mt-4 small">
                        <span class="text-muted">Chưa nhận được email? </span>
                        <a asp-action="QuenMatKhau" class="text-decoration-none fw-bold" style="color: #f39c12;">Gửi lại</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>