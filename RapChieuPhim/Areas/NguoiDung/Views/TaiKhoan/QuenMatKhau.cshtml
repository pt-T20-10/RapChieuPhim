@model RapChieuPhim.Models.ViewModels.QuenMatKhauViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                        <h4 class="fw-bold mt-2" style="color: #034ea2;">QUÊN MẬT KHẨU</h4>
                        <p class="text-muted small">Vui lòng nhập Email đã đăng ký để nhận mã OTP khôi phục.</p>
                    </div>

                    <form asp-action="QuenMatKhau" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Email"><i class="bi bi-envelope me-2"></i>Email của bạn</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn w-100 fw-bold py-3 text-white" style="background-color: #034ea2; border-radius: 50px;">
                            GỬI MÃ OTP <i class="bi bi-send ms-1"></i>
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-action="DangNhap" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left"></i> Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}