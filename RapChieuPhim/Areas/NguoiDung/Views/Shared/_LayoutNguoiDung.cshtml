@using Microsoft.AspNetCore.Http

@{
    // Đọc thông tin từ Session
    var isLogined = !string.IsNullOrEmpty(Context.Session.GetString("TenDangNhap"));
    var hoTen = Context.Session.GetString("HoTen");
    var vaiTro = Context.Session.GetString("VaiTro");

    // Kiểm tra xem có phải là Nhân viên hoặc Admin không
    var isStaff = vaiTro == "NhanVien" || vaiTro == "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rạp Chiếu Phim</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3 shadow">
            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-area="NguoiDung"
                   asp-controller="Home"
                   asp-action="Index">
                    <span style="color: #f39c12;">🎬 B E T A</span> Cinemas
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-area="NguoiDung"
                               asp-controller="Home"
                               asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-area="NguoiDung"
                               asp-controller="DatVe"
                               asp-action="Index">Đặt vé</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (isLogined)
                        {
                            <div class="user-greeting text-white d-flex align-items-center shadow-sm">
                                <i class="bi bi-person-circle fs-5 me-2" style="color: #f39c12;"></i>
                                <span class="small">
                                    Xin chào,
                                    <a asp-area="NguoiDung" asp-controller="TaiKhoan" asp-action="ThongTin" class="fw-bold" style="color: #f39c12; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
                                        @hoTen
                                    </a>
                                </span>
                            </div>

                            @if (isStaff)
                            {
                                <a class="btn btn-warning btn-sm fw-bold rounded-pill px-3 shadow-sm"
                                   asp-area="RapPhim"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    <i class="bi bi-gear-fill me-1"></i> Quản lý
                                </a>
                            }

                            <a class="btn btn-logout btn-sm px-3 fw-bold shadow-sm"
                               asp-area="NguoiDung"
                               asp-controller="TaiKhoan"
                               asp-action="DangXuat">
                                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-login-vip btn-sm fw-bold text-white"
                               asp-area="NguoiDung"
                               asp-controller="TaiKhoan"
                               asp-action="DangNhap">
                                <i class="bi bi-person-badge me-1"></i> Đăng nhập / Ưu đãi
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>

        <style>
            /* Nút Đăng nhập VIP */
            .btn-login-vip {
                background: linear-gradient(45deg, #034ea2, #007bff);
                border: none;
                border-radius: 50px;
                padding: 8px 22px;
                box-shadow: 0 4px 10px rgba(3, 78, 162, 0.3);
                transition: all 0.3s ease;
            }

                .btn-login-vip:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(3, 78, 162, 0.5);
                    color: #fff;
                }

            /* Lời chào User */
            .user-greeting {
                background-color: rgba(255, 255, 255, 0.1);
                padding: 6px 18px;
                border-radius: 50px;
                border: 1px solid rgba(255, 255, 255, 0.2);
            }

            /* Nút Đăng xuất */
            .btn-logout {
                background-color: transparent;
                border: 1px solid rgba(255, 255, 255, 0.3);
                border-radius: 50px;
                color: #fff;
                transition: all 0.3s ease;
            }

                .btn-logout:hover {
                    background-color: #dc3545;
                    border-color: #dc3545;
                    color: #fff;
                }
        </style>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4 bg-light">
        <div class="container py-3 text-center">
            &copy; 2026 - Rạp Chiếu Phim - Nhóm 1. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>