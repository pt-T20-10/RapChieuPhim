@model RapChieuPhim.Models.ViewModels.DuBaoViewModel
@{
    ViewData["Title"] = "Dự báo doanh thu chiến lược";
}

<style>
    .vip-card { border: none; border-radius: 12px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .vip-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .gradient-primary { background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; }
    .gradient-success { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white; }
    .gradient-danger { background: linear-gradient(135deg, #cb2d3e 0%, #ef473a 100%); color: white; }
    .insight-box { border-left: 5px solid #ffc107; background-color: #fffaf0; }
</style>

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-graph-up-arrow me-2"></i>Dự Báo Doanh Thu Chiến Lược</h2>
        <span class="badge bg-dark fs-6 py-2 px-3 rounded-pill"><i class="bi bi-robot me-1"></i> AI Analytics</span>
    </div>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group shadow-sm bg-white rounded-pill p-1" role="group">
            <a href="/RapPhim/ThongKe/Index" class="btn btn-light rounded-pill px-5 fw-bold text-secondary border-0">
                <i class="bi bi-bar-chart-fill me-2"></i>Thống Kê Quá Khứ
            </a>
            <a href="/RapPhim/ThongKe/DuBao" class="btn btn-primary rounded-pill px-5 fw-bold">
                <i class="bi bi-graph-up-arrow me-2"></i>Dự Báo Tương Lai
            </a>
        </div>
    </div>

    @if (!Model.DuDieuKien)
    {
        <div class="alert alert-danger shadow-sm rounded-3">
            <i class="bi bi-exclamation-triangle-fill fs-5 me-2"></i> <strong>Cảnh báo:</strong> @ViewBag.WarningMessage
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-3">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4 shadow-sm border-0 rounded-3">
        <div class="card-body bg-light rounded-3">
            <form method="get" action="/RapPhim/ThongKe/DuBao" class="row g-3 align-items-start">
                <div class="col-auto mt-2">
                    <label for="soNgay" class="col-form-label fw-bold text-secondary">Tùy chỉnh chu kỳ dự báo (ngày):</label>
                </div>
                <div class="col-auto">
                    <input type="number" id="soNgay" name="soNgay" class="form-control fw-bold text-center text-primary" 
                           value="@Model.SoNgayDuBao" min="1" required style="width: 100px;" oninput="kiemTraDauVao()">
                    <div id="msg-loi" class="text-danger mt-1 fw-bold" style="display: none; font-size: 0.85em;">
                        Vui lòng nhập số > 0
                    </div>
                </div>
                <div class="col-auto mt-2">
                    <button type="submit" id="btnApDung" class="btn btn-primary px-4 fw-bold shadow-sm">Phân tích mô hình</button>
                </div>

                @if (Model.DuDieuKien)
                {
                    <div class="col-auto ms-auto mt-2">
                        <a href="/RapPhim/ThongKe/XuatExcelDuBao?soNgay=@Model.SoNgayDuBao" class="btn btn-success fw-bold shadow-sm">
                            <i class="bi bi-file-earmark-excel"></i> Xuất Báo Cáo
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>

    @if (Model.DuDieuKien)
    {
        <div class="card shadow-sm mb-4 border-0 insight-box rounded-3">
            <div class="card-body">
                <h5 class="fw-bold text-warning text-dark"><i class="bi bi-lightbulb-fill text-warning me-2"></i>Đánh giá xu hướng từ Thuật toán</h5>
                <p class="mb-0 text-dark">
                    Hệ thống áp dụng thuật toán <strong>Trung bình trượt có trọng số (WMA)</strong> kết hợp phân tích dao động lịch sử 7 ngày qua. 
                    Dự báo trong <strong>@Model.SoNgayDuBao ngày tới</strong>, hệ thống đề xuất kịch bản cơ sở làm trọng tâm, đồng thời chuẩn bị sẵn nguồn lực F&B (Bắp/nước) cho kịch bản lạc quan nếu rơi vào các ngày cuối tuần hoặc bùng nổ truyền thông.
                </p>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card vip-card shadow-sm gradient-danger h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6 class="text-uppercase text-white-50 fw-bold">Kịch bản Bi quan (-15%)</h6>
                        <h3 class="fw-bold mb-0">@Model.KichBanBiQuan.ToString("N0") ₫</h3>
                        <small class="text-white-50 mt-2">Nguy cơ mưa bão, vắng khách</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card vip-card shadow gradient-primary h-100" style="transform: scale(1.05); z-index: 10;">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h5 class="text-uppercase text-warning fw-bold"><i class="bi bi-star-fill me-1"></i> Kịch bản Cơ sở</h5>
                        <h1 class="display-6 fw-bold mb-0 text-white mt-1">@Model.DoanhThuDuKien.ToString("N0") ₫</h1>
                        <span class="badge bg-light text-primary mt-2 mx-auto" style="width: fit-content;">Xác suất xảy ra cao nhất</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card vip-card shadow-sm gradient-success h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6 class="text-uppercase text-white-50 fw-bold">Kịch bản Lạc quan (+15%)</h6>
                        <h3 class="fw-bold mb-0">@Model.KichBanLacQuan.ToString("N0") ₫</h3>
                        <small class="text-white-50 mt-2">Hiệu ứng đám đông viral</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card shadow-sm mb-4 border-0 rounded-3 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                        <h5 class="fw-bold text-dark"><i class="bi bi-activity text-primary me-2"></i>Đường cong xu hướng (Thực tế vs Dự báo)</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="chartDuBaoVIP" style="max-height: 380px;"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm mb-4 border-0 rounded-3 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                        <h5 class="fw-bold text-dark"><i class="bi bi-table text-success me-2"></i>Bảng Phân Tích</h5>
                    </div>
                    <div class="card-body p-0 mt-3" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover mb-0 text-center align-middle">
                            <thead class="table-light sticky-top shadow-sm">
                                <tr>
                                    <th class="text-secondary">Ngày</th>
                                    <th class="text-secondary">Giá trị (VNĐ)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.DanhSachDuBao)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@item.Ngay</td>
                                        @if (item.LaDuBao)
                                        {
                                            <td class="text-primary fw-bold">
                                                @item.DoanhThu.ToString("N0") <br/>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" style="font-size: 0.7em;">Dự kiến</span>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="text-secondary">
                                                @item.DoanhThu.ToString("N0") <br/>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25" style="font-size: 0.7em;">Thực tế</span>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function kiemTraDauVao() {
            const oNhap = document.getElementById('soNgay');
            const nutBam = document.getElementById('btnApDung');
            const dongBaoLoi = document.getElementById('msg-loi');
            const giaTri = parseInt(oNhap.value);
            if (!oNhap.value || giaTri < 1) {
                oNhap.classList.add('is-invalid');
                dongBaoLoi.style.display = 'block';
                nutBam.disabled = true;
            } else {
                oNhap.classList.remove('is-invalid');
                dongBaoLoi.style.display = 'none';
                nutBam.disabled = false;
            }
        }
        kiemTraDauVao();

        const ctx = document.getElementById('chartDuBaoVIP');
        if (ctx) {
            const context = ctx.getContext('2d');
            const gradientFill = context.createLinearGradient(0, 0, 0, 400);
            gradientFill.addColorStop(0, 'rgba(54, 162, 235, 0.4)');
            gradientFill.addColorStop(1, 'rgba(54, 162, 235, 0.0)');

            const labels = [@Html.Raw(string.Join(",", Model.DanhSachDuBao.Select(x => $"'{x.Ngay}'")))];
            const dataValues = [@string.Join(",", Model.DanhSachDuBao.Select(x => x.DoanhThu))];
            const laDuBao = [@string.Join(",", Model.DanhSachDuBao.Select(x => x.LaDuBao.ToString().ToLower()))];
            
            const pointColors = laDuBao.map(d => d ? '#ffc107' : '#0d6efd');
            const pointStyles = laDuBao.map(d => d ? 'rectRot' : 'circle');
            const pointRadius = laDuBao.map(d => d ? 6 : 4);

            new Chart(context, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Lưu lượng Doanh Thu',
                        data: dataValues,
                        borderColor: '#0d6efd',
                        backgroundColor: gradientFill,
                        borderWidth: 3,
                        pointBackgroundColor: pointColors,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointStyle: pointStyles,
                        pointRadius: pointRadius,
                        fill: true,
                        tension: 0.4,
                        segment: {
                            borderDash: ctx => laDuBao[ctx.p1DataIndex] ? [6, 6] : undefined,
                            borderColor: ctx => laDuBao[ctx.p1DataIndex] ? '#ffc107' : '#0d6efd'
                        }
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false } },
                        y: { ticks: { callback: value => (value/1000000).toLocaleString('vi-VN') + ' Tr' } }
                    }
                }
            });
        }
    </script>
}