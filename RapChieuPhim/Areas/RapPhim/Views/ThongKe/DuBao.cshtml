@model RapChieuPhim.Models.ViewModels.DuBaoViewModel
@{
    ViewData["Title"] = "Dự báo doanh thu";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Dự Báo Doanh Thu Kỳ Vọng</h2>

    @if (!Model.DuDieuKien)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.WarningMessage
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" action="/RapPhim/ThongKe/DuBao" class="row g-3 align-items-start">
                <div class="col-auto mt-2">
                    <label for="soNgay" class="col-form-label fw-bold">Tùy chỉnh tham số dự báo (ngày):</label>
                </div>
                <div class="col-auto">
                    <input type="number" id="soNgay" name="soNgay" class="form-control" value="@Model.SoNgayDuBao" required oninput="kiemTraDauVao()">
                    
                    <div id="msg-loi" class="text-danger mt-1 fw-bold" style="display: none; font-size: 0.85em;">
                        Vui lòng nhập số nguyên dương
                    </div>
                </div>
                <div class="col-auto mt-2">
                    <button type="submit" id="btnApDung" class="btn btn-primary">Áp dụng</button>
                </div>

                @if (Model.DuDieuKien)
                {
                    <div class="col-auto ms-auto mt-2">
                        <a href="/RapPhim/ThongKe/XuatExcelDuBao?soNgay=@Model.SoNgayDuBao" class="btn btn-success">
                            <i class="bi bi-file-earmark-excel"></i> Xuất báo cáo dự báo
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>

    @if (Model.DuDieuKien)
    {
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card bg-dark text-white shadow">
                    <div class="card-body text-center">
                        <h5>DOANH THU DỰ KIẾN TRONG @Model.SoNgayDuBao NGÀY TỚI</h5>
                        <h1 class="display-4 text-warning">@Model.DoanhThuDuKien.ToString("N0") ₫</h1>
                        <p class="mb-0 text-muted">* Tính toán dựa trên hiệu suất 7 ngày gần nhất</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-bold">Bảng số liệu chi tiết</div>
                    <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-striped table-hover mb-0 text-center">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Ngày</th>
                                    <th>Doanh Thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.DanhSachDuBao)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.Ngay</td>
                                        @if (item.LaDuBao)
                                        {
                                            <td class="text-success fw-bold">@item.DoanhThu.ToString("N0") ₫ <span class="badge bg-warning text-dark ms-1">Dự báo</span></td>
                                        }
                                        else
                                        {
                                            <td class="text-muted">@item.DoanhThu.ToString("N0") ₫</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Biểu đồ trực quan</span>
                        <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseChart" aria-expanded="false">
                            <i class="bi bi-bar-chart-fill"></i> Xem biểu đồ xu hướng
                        </button>
                    </div>
                    <div class="collapse" id="collapseChart">
                        <div class="card-body">
                            <canvas id="chartDuBao" style="max-height: 350px;"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // XỬ LÝ NGOẠI LỆ 5.a: Khóa nút và báo lỗi đỏ khi nhập sai
        function kiemTraDauVao() {
            const oNhap = document.getElementById('soNgay');
            const nutBam = document.getElementById('btnApDung');
            const dongBaoLoi = document.getElementById('msg-loi');
            
            // Lấy giá trị đang nhập (chuyển sang số nguyên)
            const giaTri = parseInt(oNhap.value);

            // Nếu ô trống hoặc nhỏ hơn 1 (số âm, số 0)
            if (!oNhap.value || giaTri < 1) {
                oNhap.classList.add('is-invalid'); // Tô viền đỏ ô nhập
                dongBaoLoi.style.display = 'block'; // Hiện dòng chữ đỏ
                nutBam.disabled = true; // Làm mờ và khóa nút bấm
            } else {
                oNhap.classList.remove('is-invalid'); // Bỏ viền đỏ
                dongBaoLoi.style.display = 'none'; // Ẩn dòng chữ
                nutBam.disabled = false; // Mở khóa nút bấm
            }
        }

        // Chạy hàm kiểm tra ngay khi vừa load trang để đề phòng
        kiemTraDauVao();
        const ctx = document.getElementById('chartDuBao');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.DanhSachDuBao.Select(x => $"'{x.Ngay}'")))],
                    datasets: [{
                        label: 'Doanh thu (₫)',
                        data: [@string.Join(",", Model.DanhSachDuBao.Select(x => x.DoanhThu))],
                        borderColor: 'rgba(255, 193, 7, 1)',
                        backgroundColor: 'rgba(255, 193, 7, 0.2)',
                        fill: true,
                        tension: 0.3,
                        pointBackgroundColor: [@Html.Raw(string.Join(",", Model.DanhSachDuBao.Select(x => x.LaDuBao ? "'#198754'" : "'#6c757d'")))]
                    }]
                }
            });
        }
    </script>
}