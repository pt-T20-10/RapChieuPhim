@model RapChieuPhim.Models.ViewModels.ThongKeViewModel
@{
    ViewData["Title"] = "Thống kê hoạt động";
}

<div class="container-fluid mt-4 mb-5">
    <h2 class="mb-4">Thống Kê Hoạt Động Doanh Thu</h2>

    <div class="d-flex justify-content-center mb-4">
        <div class="btn-group shadow-sm bg-white rounded-pill p-1" role="group">
            <a href="/RapPhim/ThongKe/Index" class="btn btn-primary rounded-pill px-5 fw-bold">
                <i class="bi bi-bar-chart-fill me-2"></i>Thống Kê Quá Khứ
            </a>
            <a href="/RapPhim/ThongKe/DuBao" class="btn btn-light rounded-pill px-5 fw-bold text-secondary border-0">
                <i class="bi bi-graph-up-arrow me-2"></i>Dự Báo Tương Lai
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (ViewBag.InfoMessage != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle"></i> @ViewBag.InfoMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" action="/RapPhim/ThongKe/Index" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label for="tuNgay" class="col-form-label fw-bold">Từ ngày:</label>
                </div>
                <div class="col-auto">
                    <input type="date" id="tuNgay" name="tuNgay" class="form-control form-control-sm" value="@ViewBag.TuNgay" required>
                </div>
                <div class="col-auto">
                    <label for="denNgay" class="col-form-label fw-bold">Đến ngày:</label>
                </div>
                <div class="col-auto">
                    <input type="date" id="denNgay" name="denNgay" class="form-control form-control-sm" value="@ViewBag.DenNgay" required>
                </div>

                <div class="col-auto">
                    <select id="maPhim" name="maPhim" class="form-select form-select-sm">
                        <option value="">-- Tất cả Phim --</option>
                        @if (ViewBag.PhimList != null)
                        {
                            foreach (var item in ViewBag.PhimList)
                            {
                                if (item.Value == ViewBag.SelectedPhim)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <select id="maPhong" name="maPhong" class="form-select form-select-sm">
                        <option value="">-- Tất cả Phòng --</option>
                        @if (ViewBag.PhongList != null)
                        {
                            foreach (var item in ViewBag.PhongList)
                            {
                                if (item.Value == ViewBag.SelectedPhong)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel"></i> Lọc dữ liệu</button>
                </div>

                <div class="col-auto ms-auto">
                    <a href="/RapPhim/ThongKe/XuatExcel?tuNgay=@ViewBag.TuNgay&denNgay=@ViewBag.DenNgay&maPhim=@ViewBag.SelectedPhim&maPhong=@ViewBag.SelectedPhong" class="btn btn-success btn-sm">
                        <i class="bi bi-file-earmark-excel"></i> Xuất báo cáo đối soát
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow-sm h-100">
                <div class="card-header">Tổng Doanh Thu</div>
                <div class="card-body d-flex align-items-center">
                    <h3 class="card-title mb-0">@Model.TongDoanhThu.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3 shadow-sm h-100">
                <div class="card-header">Tổng Đơn Hàng</div>
                <div class="card-body d-flex align-items-center">
                    <h3 class="card-title mb-0">@Model.TongSoDonHang <small class="fs-6 text-white-50">đơn</small></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3 shadow-sm h-100">
                <div class="card-header text-dark">Tổng Số Vé Bán Ra</div>
                <div class="card-body d-flex align-items-center">
                    <h3 class="card-title text-dark mb-0">@Model.TongSoVe <small class="fs-6 text-black-50">vé</small></h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">Biểu đồ doanh thu theo ngày</div>
        <div class="card-body">
            <canvas id="chartDoanhThu" style="max-height: 400px;"></canvas>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4 border-0 h-100">
                <div class="card-header bg-white fw-bold">Top 5 Phim Có Doanh Thu Cao Nhất</div>
                <div class="card-body p-0" style="overflow-x: auto;">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Tên Phim</th>
                                <th>Số Vé</th>
                                <th>Doanh Thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopPhim.Any())
                            {
                                int stt = 1;
                                foreach (var item in Model.TopPhim)
                                {
                                    <tr>
                                        <td>@stt</td>
                                        <td class="fw-bold text-primary">@item.TenPhim</td>
                                        <td>@item.SoVe</td>
                                        <td class="fw-bold">@item.DoanhThu.ToString("N0") ₫</td>
                                    </tr>
                                    stt++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4 border-0 h-100">
                <div class="card-header bg-white fw-bold">Tỷ Lệ Lấp Đầy Theo Phòng</div>
                <div class="card-body p-0" style="overflow-x: auto;">
                    <table class="table table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Phòng Chiếu</th>
                                <th>Ghế Phục Vụ</th>
                                <th>Đã Đặt</th>
                                <th>Tỷ Lệ Lấp Đầy</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LapDayTheoPhong.Any())
                            {
                                foreach (var item in Model.LapDayTheoPhong)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.TenPhong</td>
                                        <td>@item.TongGhe</td>
                                        <td>@item.GheDaDat</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="me-2" style="min-width: 45px;">@item.TyLe%</span>
                                                <div class="progress flex-grow-1" style="height: 8px;">
                                                    <div class="progress-bar @(item.TyLe >= 70 ? "bg-success" : item.TyLe >= 40 ? "bg-warning" : "bg-danger")"
                                                         role="progressbar" style="width: @item.TyLe%"
                                                         aria-valuenow="@item.TyLe" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mt-2">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white fw-bold"><i class="bi bi-pie-chart-fill text-danger me-2"></i>Cơ Cấu Doanh Thu Theo Thể Loại & Loại Ghế</div>
                <div class="card-body row align-items-center">
                    <div class="col-md-6 text-center">
                        <canvas id="chartTheLoai" style="max-height: 280px;"></canvas>
                    </div>
                    <div class="col-md-6 mt-4 mt-md-0">
                        <h6 class="fw-bold mb-3">Tỷ lệ vé bán ra (VIP vs Thường):</h6>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-secondary fw-bold">Vé Thường (@Model.SoVeThuong vé)</span>
                            <span class="text-warning fw-bold text-dark">Vé VIP (@Model.SoVeVIP vé)</span>
                        </div>
                        <div class="progress shadow-sm" style="height: 25px;">
                            @{
                                double ptThuong = Model.TongSoVe > 0 ? (Model.SoVeThuong * 100.0 / Model.TongSoVe) : 0;
                                double ptVIP = Model.TongSoVe > 0 ? (Model.SoVeVIP * 100.0 / Model.TongSoVe) : 0;
                            }
                            <div class="progress-bar bg-info" role="progressbar" style="width: @ptThuong%">@Math.Round(ptThuong)%</div>
                            <div class="progress-bar bg-warning text-dark fw-bold" role="progressbar" style="width: @ptVIP%">@Math.Round(ptVIP)%</div>
                        </div>
                        <div class="mt-4 text-muted small">
                            <i class="bi bi-lightbulb-fill text-warning"></i> <em>Lưu ý: Doanh thu thể loại được trích xuất dựa trên bộ lọc thời gian hiện tại và đã được phân bổ tự động chiết khấu khuyến mãi (nếu có).</em>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 1. VẼ BIỂU ĐỒ CỘT DOANH THU NGÀY
            const ctxBar = document.getElementById('chartDoanhThu').getContext('2d');
            const rawLabels = [@Html.Raw(string.Join(",", Model.DoanhThuTheoNgay.Select(x => $"'{x.Ngay}'")))];
            const rawData = [@string.Join(",", Model.DoanhThuTheoNgay.Select(x => x.DoanhThu))];

            if (rawLabels.length > 0 && rawData.length > 0) {
                new Chart(ctxBar, {
                    type: 'bar',
                    data: {
                        labels: rawLabels,
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: rawData,
                            backgroundColor: 'rgba(54, 162, 235, 0.7)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1,
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { callback: function(value) { return value.toLocaleString('vi-VN') + ' ₫'; } }
                            }
                        },
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) { label += ': '; }
                                        if (context.parsed.y !== null) { label += context.parsed.y.toLocaleString('vi-VN') + ' ₫'; }
                                        return label;
                                    }
                                }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('chartDoanhThu').style.display = 'none';
            }

            // 2. VẼ BIỂU ĐỒ TRÒN THỂ LOẠI (THÊM MỚI)
            const ctxPie = document.getElementById('chartTheLoai');
            const theLoaiLabels = [@Html.Raw(string.Join(",", Model.DoanhThuTheoTheLoai.Select(x => $"'{x.TenTheLoai}'")))];
            const theLoaiData = [@string.Join(",", Model.DoanhThuTheoTheLoai.Select(x => x.DoanhThu))];

            if (ctxPie && theLoaiLabels.length > 0 && theLoaiData.length > 0) {
                new Chart(ctxPie.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: theLoaiLabels,
                        datasets: [{
                            data: theLoaiData,
                            backgroundColor: ['#ff6384', '#36a2eb', '#ffce56', '#4bc0c0', '#9966ff', '#ff9f40'],
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'right' },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let value = context.raw || 0;
                                        return ' ' + value.toLocaleString('vi-VN') + ' ₫';
                                    }
                                }
                            }
                        }
                    }
                });
            } else if (ctxPie) {
                 ctxPie.style.display = 'none';
            }
        });
    </script>
}