@model RapChieuPhim.Models.ViewModels.ThongKeViewModel
@{
    ViewData["Title"] = "Thống kê hoạt động";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Thống Kê Hoạt Động Doanh Thu</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (ViewBag.InfoMessage != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle"></i> @ViewBag.InfoMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" action="/RapPhim/ThongKe/Index" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label for="tuNgay" class="col-form-label fw-bold">Từ ngày:</label>
                </div>
                <div class="col-auto">
                    <input type="date" id="tuNgay" name="tuNgay" class="form-control form-control-sm" value="@ViewBag.TuNgay" required>
                </div>
                <div class="col-auto">
                    <label for="denNgay" class="col-form-label fw-bold">Đến ngày:</label>
                </div>
                <div class="col-auto">
                    <input type="date" id="denNgay" name="denNgay" class="form-control form-control-sm" value="@ViewBag.DenNgay" required>
                </div>

                <div class="col-auto">
                    <select id="maPhim" name="maPhim" class="form-select form-select-sm">
                        <option value="">-- Tất cả Phim --</option>
                        @if (ViewBag.PhimList != null)
                        {
                            foreach (var item in ViewBag.PhimList)
                            {
                                if (item.Value == ViewBag.SelectedPhim)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <select id="maPhong" name="maPhong" class="form-select form-select-sm">
                        <option value="">-- Tất cả Phòng --</option>
                        @if (ViewBag.PhongList != null)
                        {
                            foreach (var item in ViewBag.PhongList)
                            {
                                if (item.Value == ViewBag.SelectedPhong)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-funnel"></i> Lọc dữ liệu</button>
                </div>

                <div class="col-auto ms-auto">
                    <a href="/RapPhim/ThongKe/XuatExcel?tuNgay=@ViewBag.TuNgay&denNgay=@ViewBag.DenNgay&maPhim=@ViewBag.SelectedPhim&maPhong=@ViewBag.SelectedPhong" class="btn btn-success btn-sm">
                        <i class="bi bi-file-earmark-excel"></i> Xuất báo cáo đối soát
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3 shadow-sm">
                <div class="card-header">Tổng Doanh Thu</div>
                <div class="card-body">
                    <h3 class="card-title">@Model.TongDoanhThu.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3 shadow-sm">
                <div class="card-header">Tổng Đơn Hàng</div>
                <div class="card-body">
                    <h3 class="card-title">@Model.TongSoDonHang <small class="fs-6">đơn</small></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3 shadow-sm">
                <div class="card-header text-dark">Tổng Số Vé Bán Ra</div>
                <div class="card-body">
                    <h3 class="card-title text-dark">@Model.TongSoVe <small class="fs-6">vé</small></h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header fw-bold">Biểu đồ doanh thu theo ngày</div>
        <div class="card-body">
            <canvas id="chartDoanhThu" style="max-height: 400px;"></canvas>
        </div>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-bold">Top 5 Phim Có Doanh Thu Cao Nhất</div>
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Tên Phim</th>
                                <th>Số Vé Bán</th>
                                <th>Doanh Thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopPhim.Any())
                            {
                                int stt = 1;
                                foreach (var item in Model.TopPhim)
                                {
                                    <tr>
                                        <td>@stt</td>
                                        <td class="fw-bold text-primary">@item.TenPhim</td>
                                        <td>@item.SoVe</td>
                                        <td>@item.DoanhThu.ToString("N0") ₫</td>
                                    </tr>
                                    stt++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm mb-4">
                <div class="card-header fw-bold">Tỷ Lệ Lấp Đầy Theo Phòng</div>
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Phòng Chiếu</th>
                                <th>Tổng Ghế Phục Vụ</th>
                                <th>Ghế Đã Đặt</th>
                                <th>Tỷ Lệ Lấp Đầy</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LapDayTheoPhong.Any())
                            {
                                foreach (var item in Model.LapDayTheoPhong)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.TenPhong</td>
                                        <td>@item.TongGhe</td>
                                        <td>@item.GheDaDat</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="me-2">@item.TyLe%</span>
                                                <div class="progress flex-grow-1" style="height: 8px;">
                                                    <div class="progress-bar @(item.TyLe >= 70 ? "bg-success" : item.TyLe >= 40 ? "bg-warning" : "bg-danger")"
                                                         role="progressbar" style="width: @item.TyLe%"
                                                         aria-valuenow="@item.TyLe" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có dữ liệu</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('chartDoanhThu').getContext('2d');
            const rawLabels = [@Html.Raw(string.Join(",", Model.DoanhThuTheoNgay.Select(x => $"'{x.Ngay}'")))];
            const rawData = [@string.Join(",", Model.DoanhThuTheoNgay.Select(x => x.DoanhThu))];

            if (rawLabels.length > 0 && rawData.length > 0) {
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: rawLabels,
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: rawData,
                            backgroundColor: 'rgba(54, 162, 235, 0.6)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1,
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) { return value.toLocaleString('vi-VN') + ' ₫'; }
                                }
                            }
                        },
                        plugins: {
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) { label += ': '; }
                                        if (context.parsed.y !== null) { label += context.parsed.y.toLocaleString('vi-VN') + ' ₫'; }
                                        return label;
                                    }
                                }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('chartDoanhThu').style.display = 'none';
            }
        });
    </script>
}