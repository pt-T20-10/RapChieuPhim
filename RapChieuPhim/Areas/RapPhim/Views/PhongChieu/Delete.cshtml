@model RapChieuPhim.Models.Entities.PhongChieu
@{
    ViewData["Title"] = "Xóa Phòng chiếu";
    bool coRangBuoc = ViewBag.CoRangBuoc == true;
}

<div class="mb-3">
    <a asp-action="Index" asp-area="RapPhim" class="btn btn-outline-secondary">← Quay lại</a>
</div>

<div class="card shadow-sm" style="max-width:520px">
    <div class="card-header @(coRangBuoc ? "bg-warning text-dark" : "bg-danger text-white")">
        <h5 class="mb-0">@(coRangBuoc ? "⚠️ Không thể xóa phòng chiếu này" : "🗑️ Xác nhận xóa phòng chiếu")</h5>
    </div>
    <div class="card-body">

        <dl class="row mb-3">
            <dt class="col-sm-4">Mã phòng</dt>
            <dd class="col-sm-8"><code>@Model.MaPhong</code></dd>

            <dt class="col-sm-4">Tên phòng</dt>
            <dd class="col-sm-8">@Model.TenPhong</dd>

            <dt class="col-sm-4">Loại phòng</dt>
            <dd class="col-sm-8">@(Model.MaLoaiPhongNavigation?.TenLoaiPhong ?? Model.MaLoaiPhong)</dd>

            <dt class="col-sm-4">Số ghế</dt>
            <dd class="col-sm-8">@Model.SoGhe ghế</dd>

            <dt class="col-sm-4">Trạng thái</dt>
            <dd class="col-sm-8">@Model.TrangThai</dd>
        </dl>

        @if (coRangBuoc)
        {
            <div class="alert alert-danger">
                <strong>🚫 Không thể xóa — dữ liệu đang được sử dụng trong hệ thống</strong>
                <ul class="mb-0 mt-2 small">
                    @if (ViewBag.SoSuatChieu > 0)
                    {
                        <li>Phòng đang có <strong>@ViewBag.SoSuatChieu suất chiếu</strong> chưa kết thúc</li>
                    }
                    @if (ViewBag.SoGheDaDat > 0)
                    {
                        <li>Có <strong>@ViewBag.SoGheDaDat ghế</strong> đang được đặt hoặc giữ</li>
                    }
                </ul>
                <p class="mb-0 mt-2 small">Vui lòng hủy tất cả suất chiếu và đặt ghế trước khi xóa.</p>
            </div>
            <a asp-action="Index" asp-area="RapPhim" class="btn btn-secondary">Quay lại danh sách</a>
        }
        else
        {
            <div class="alert alert-warning">
                <strong>⚠️ Bạn có chắc muốn xóa bản ghi này không?</strong>
                <p class="mb-0 mt-1 small">Phòng chiếu sẽ bị ẩn khỏi hệ thống. Hành động này không thể hoàn tác.</p>
            </div>
            <form asp-action="Delete" asp-area="RapPhim" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MaPhong" />
                <button type="submit" class="btn btn-danger">🗑️ Đồng ý, xóa</button>
                <a asp-action="Index" asp-area="RapPhim" class="btn btn-outline-secondary ms-2">Hủy, quay lại</a>
            </form>
        }
    </div>
</div>
