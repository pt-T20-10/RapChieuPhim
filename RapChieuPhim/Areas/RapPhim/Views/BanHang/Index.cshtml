@{
    ViewData["Title"] = "Bán hàng";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
    <h3 class="fw-bold mb-2">Chọn loại giao dịch</h3>
    <p class="text-muted mb-5">Nhân viên chọn quầy phù hợp để bắt đầu</p>

    <div class="row g-4 w-100" style="max-width: 700px;">
        <div class="col-md-6">
            <a asp-action="BanVe" asp-controller="BanHang" asp-area="RapPhim"
               class="text-decoration-none">
                <div class="card border-0 shadow text-center p-5 h-100
                            border-top border-4 border-primary">
                    <div style="font-size:4rem">🎬</div>
                    <h4 class="fw-bold mt-3 mb-2">Bán vé</h4>
                    <p class="text-muted small mb-0">
                        Chọn phim, suất chiếu và ghế cho khách
                    </p>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a asp-action="BanDichVu" asp-controller="BanHang" asp-area="RapPhim"
               class="text-decoration-none">
                <div class="card border-0 shadow text-center p-5 h-100
                            border-top border-4 border-warning">
                    <div style="font-size:4rem">🍿</div>
                    <h4 class="fw-bold mt-3 mb-2">Bán dịch vụ</h4>
                    <p class="text-muted small mb-0">
                        Bán bắp nước và đồ ăn tại quầy
                    </p>
                </div>
            </a>
        </div>
    </div>
</div>