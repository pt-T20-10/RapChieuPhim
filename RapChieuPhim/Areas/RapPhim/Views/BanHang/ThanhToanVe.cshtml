@model RapChieuPhim.Models.Entities.DonHang
@{
    ViewData["Title"] = "Thanh toán vé";
    var ve0 = Model.ChiTietVe.First();
    var suat = ve0.MaSuatChieuNavigation;
}

<div class="row g-4">

    @* ── Cột trái: tóm tắt đơn + voucher ── *@
    <div class="col-lg-7">
        <h5 class="fw-bold text-primary mb-3">
            <i class="bi bi-receipt me-1"></i> Tóm tắt đơn hàng
        </h5>

        @* Card thông tin phim + ghế *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <div class="d-flex gap-3 mb-3">
                    <img src="@(suat.MaPhimNavigation.DuongDanAnh ?? "/images/default/no-poster.jpg")"
                         class="rounded" style="width:80px;height:110px;object-fit:cover;"
                         onerror="this.src='/images/default/no-poster.jpg'">
                    <div>
                        <h6 class="fw-bold">@suat.MaPhimNavigation.TenPhim</h6>
                        <div class="small text-muted">
                            <i class="bi bi-clock me-1"></i>
                            @suat.ThoiGianBatDau.ToString("HH:mm — dd/MM/yyyy")
                        </div>
                        <div class="small text-muted">
                            <i class="bi bi-building me-1"></i>
                            @suat.MaPhongNavigation.TenPhong
                        </div>
                        <div class="mt-2 d-flex flex-wrap gap-1">
                            @foreach (var ve in Model.ChiTietVe)
                            {
                                <span class="badge bg-primary fs-6 px-3">
                                    @(ve.MaGheNavigation.TenHang + ve.MaGheNavigation.SoThu)
                                    <small class="fw-normal">
                                        @ve.MaGheNavigation.MaLoaiGheNavigation.TenLoaiGhe
                                    </small>
                                </span>
                            }
                        </div>
                    </div>
                </div>

                <table class="table table-sm small mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ghế</th>
                            <th>Loại</th>
                            <th class="text-end">Giá vé</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ve in Model.ChiTietVe)
                        {
                            <tr>
                                <td>@(ve.MaGheNavigation.TenHang + ve.MaGheNavigation.SoThu)</td>
                                <td>@ve.MaGheNavigation.MaLoaiGheNavigation.TenLoaiGhe</td>
                                <td class="text-end fw-semibold">@ve.GiaVe.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Card voucher + tổng tiền *@
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3">
                    <i class="bi bi-ticket-perforated me-1 text-primary"></i> Mã khuyến mãi
                </h6>
                <div class="input-group">
                    <input type="text" id="maVoucher" class="form-control text-uppercase"
                           placeholder="Nhập mã giảm giá">
                    <button class="btn btn-outline-primary fw-bold"
                            type="button" onclick="apDungVoucher()">
                        ÁP DỤNG
                    </button>
                    <button class="btn btn-outline-secondary fw-bold"
                            type="button" id="btnHuyVoucher"
                            onclick="huyVoucher()" style="display:none">
                        HỦY
                    </button>
                </div>
                <div id="voucherMsg" class="small mt-2 fw-semibold"></div>

                <div class="mt-3 p-3 bg-light rounded">
                    <div class="d-flex justify-content-between small text-muted">
                        <span>Tạm tính:</span>
                        <span>@Model.TongTienBanDau.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between small text-success fw-bold d-none"
                         id="rowGiam">
                        <span>Giảm giá:</span>
                        <span id="lblTienGiam"></span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold border-top pt-2 mt-2">
                        <span>Tổng cộng:</span>
                        <span class="text-danger fs-6" id="lblTongCuoi">
                            @Model.TongTienSauGiam.ToString("N0") ₫
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Cột phải: chọn hình thức thanh toán ── *@
    <div class="col-lg-5">
        <h5 class="fw-bold text-primary mb-3">
            <i class="bi bi-credit-card me-1"></i> Thanh toán
        </h5>

        <ul class="nav nav-pills mb-3" id="payTab">
            <li class="nav-item">
                <button class="nav-link active fw-bold px-4"
                        data-bs-toggle="pill" data-bs-target="#tabTienMat">
                    <i class="bi bi-cash-coin me-1"></i> Tiền mặt
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link fw-bold px-4"
                        data-bs-toggle="pill" data-bs-target="#tabQR">
                    <i class="bi bi-qr-code me-1"></i> QR / Chuyển khoản
                </button>
            </li>
        </ul>

        <div class="tab-content">

            @* Tab tiền mặt *@
            <div class="tab-pane fade show active" id="tabTienMat">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Số tiền khách đưa (₫)</label>
                            <input type="number" id="tienNhan" class="form-control form-control-lg"
                                   placeholder="Nhập số tiền"
                                   oninput="tinhTienThua()">
                        </div>
                        <div class="p-3 bg-light rounded mb-3">
                            <div class="d-flex justify-content-between">
                                <span>Cần thanh toán:</span>
                                <strong id="lblCanThanhToan">
                                    @Model.TongTienSauGiam.ToString("N0") ₫
                                </strong>
                            </div>
                            <div class="d-flex justify-content-between text-success fw-bold">
                                <span>Tiền thừa trả lại:</span>
                                <span id="tienThua">0 ₫</span>
                            </div>
                        </div>
                        <button class="btn btn-success w-100 fw-bold btn-lg"
                                onclick="xacNhanTienMat()">
                            <i class="bi bi-check-lg me-1"></i> Xác nhận thanh toán
                        </button>
                    </div>
                </div>
            </div>

            @* Tab QR *@
            <div class="tab-pane fade" id="tabQR">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <p class="text-muted mb-3">
                            Nhấn nút bên dưới để tạo mã QR chuyển khoản.
                            Khách quét mã và thanh toán trực tiếp.
                        </p>
                        <button class="btn btn-primary w-100 fw-bold btn-lg"
                                id="btnTaoQR" onclick="taoQR()">
                            <i class="bi bi-qr-code-scan me-1"></i> Tạo mã QR thanh toán
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tongTien = @Model.TongTienSauGiam;
        var maDonHang = '@Model.MaDonHang';

        // ── Voucher ──────────────────────────────────────────
        function apDungVoucher() {
            var maCode = $('#maVoucher').val().trim();
            if (!maCode) return;

            $.post('@Url.Action("ApDungKhuyenMai", "BanHang", new { area = "RapPhim" })',
                { maCode: maCode, maDonHang: maDonHang },
                function (res) {
                    var msg = $('#voucherMsg');
                    if (res.success) {
                        msg.removeClass('text-danger').addClass('text-success').text(res.message);
                        tongTien = res.tongTienMoi;

                        // Cập nhật tổng tiền bên trái
                        $('#rowGiam').removeClass('d-none');
                        $('#lblTienGiam').text('-' + res.tienGiam.toLocaleString('vi-VN') + ' ₫');
                        $('#lblTongCuoi').text(res.tongTienMoi.toLocaleString('vi-VN') + ' ₫');

                        // Cập nhật "Cần thanh toán" bên phải
                        $('#lblCanThanhToan').text(res.tongTienMoi.toLocaleString('vi-VN') + ' ₫');

                        $('#btnHuyVoucher').show();
                        $('#maVoucher').prop('readonly', true);

                        // Reset tiền thừa
                        $('#tienNhan').val('');
                        $('#tienThua').text('0 ₫');
                    } else {
                        msg.removeClass('text-success').addClass('text-danger').text(res.message);
                    }
                });
        }

        function huyVoucher() {
            $.post('@Url.Action("HuyKhuyenMai", "BanHang", new { area = "RapPhim" })',
                { maDonHang: maDonHang },
                function (res) {
                    if (res.success) {
                        tongTien = res.tongTienGoc;

                        $('#voucherMsg').text('');
                        $('#maVoucher').val('').prop('readonly', false);
                        $('#rowGiam').addClass('d-none');
                        $('#lblTongCuoi').text(res.tongTienGoc.toLocaleString('vi-VN') + ' ₫');
                        $('#lblCanThanhToan').text(res.tongTienGoc.toLocaleString('vi-VN') + ' ₫');
                        $('#btnHuyVoucher').hide();

                        // Reset tiền thừa
                        $('#tienNhan').val('');
                        $('#tienThua').text('0 ₫');
                    }
                });
        }

        // ── Tiền mặt ─────────────────────────────────────────
        function tinhTienThua() {
            var nhan = parseFloat($('#tienNhan').val()) || 0;
            var thua = nhan - tongTien;
            $('#tienThua').text(thua >= 0
                ? thua.toLocaleString('vi-VN') + ' ₫'
                : '⚠ Chưa đủ tiền');
            $('#tienThua').toggleClass('text-danger', thua < 0)
                         .toggleClass('text-success', thua >= 0);
        }

        function xacNhanTienMat() {
            var tienNhan = parseFloat($('#tienNhan').val()) || 0;
            if (tienNhan < tongTien) {
                alert('Số tiền nhận chưa đủ!');
                return;
            }
            $.post('@Url.Action("XuLyTienMat", "BanHang", new { area = "RapPhim" })',
                { maDonHang: maDonHang, tienNhan: tienNhan },
                function (res) {
                    if (res.success) {
                        var thua = res.tienThua.toLocaleString('vi-VN');
                        if (confirm('Tiền thừa trả lại: ' + thua + ' ₫\n\nXác nhận và in vé?')) {
                            window.location.href = res.redirectUrl;
                        }
                    } else {
                        alert(res.message);
                    }
                });
        }

        // ── QR PayOS ─────────────────────────────────────────
        function taoQR() {
            $('#btnTaoQR').prop('disabled', true).text('Đang tạo mã...');
            $.post('@Url.Action("TaoThanhToanQR", "BanHang", new { area = "RapPhim" })',
                { maDonHang: maDonHang },
                function (res) {
                    if (res.success) {
                        window.open(res.checkoutUrl, '_blank');
                        $('#btnTaoQR').text('Đã mở trang thanh toán — chờ khách quét');
                    } else {
                        alert('Không thể tạo mã QR. Vui lòng thử lại!');
                        $('#btnTaoQR').prop('disabled', false).text('Tạo mã QR thanh toán');
                    }
                });
        }
    </script>
}
