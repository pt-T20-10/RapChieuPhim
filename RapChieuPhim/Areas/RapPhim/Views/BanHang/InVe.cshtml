@model RapChieuPhim.Models.Entities.DonHang
@{
    ViewData["Title"] = "In vé";
    Layout = null; // Layout riêng cho trang in
    var ve0 = Model.ChiTietVe.First();
    var suat = ve0.MaSuatChieuNavigation;
    var tt = Model.ThanhToan.FirstOrDefault();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>In vé — @suat.MaPhimNavigation.TenPhim</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f0f0f0;
            font-family: 'Courier New', monospace;
        }

        .print-area {
            max-width: 720px;
            margin: 20px auto;
            background: #fff;
            padding: 24px;
            border-radius: 8px;
        }

        .ticket {
            border: 2px dashed #dee2e6;
            border-radius: 12px;
            margin-bottom: 16px;
            overflow: hidden;
        }

        .ticket-header {
            background: #1a1a2e;
            color: #fff;
            padding: 12px 16px;
        }

        .ticket-body {
            padding: 12px 16px;
        }

        .qr-area {
            background: #f8f9fa;
            text-align: center;
            padding: 12px;
            border-top: 2px dashed #dee2e6;
        }

        .invoice {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 16px;
            margin-top: 16px;
        }

        .divider {
            border-top: 1px dashed #dee2e6;
            margin: 8px 0;
        }

        @@media print {
            body {
                background: #fff;
            }

            .print-area {
                margin: 0;
                padding: 0;
                box-shadow: none;
                border-radius: 0;
            }

            .no-print {
                display: none !important;
            }

            .ticket {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>
    <div class="print-area">

       
        <div class="text-center mb-3 no-print">
            <button onclick="window.print()" class="btn btn-primary fw-bold px-5">
                🖨️ In vé & Hóa đơn
            </button>
            <a asp-action="BanVe" asp-controller="BanHang" asp-area="RapPhim"
               class="btn btn-outline-secondary ms-2">Bán vé tiếp</a>
        </div>

    
        @foreach (var ve in Model.ChiTietVe)
        {
            <div class="ticket">
                <div class="ticket-header d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-bold fs-6">🎬 RẠP CHIẾU PHIM</div>
                        <div style="font-size:10px;opacity:.7;">VÉ XEM PHIM</div>
                    </div>
                    <span class="badge bg-success">Hợp lệ</span>
                </div>
                <div class="ticket-body">
                    <div class="fw-bold fs-5 mb-1">
                        @ve.MaSuatChieuNavigation.MaPhimNavigation.TenPhim
                        <small class="text-muted fw-normal fs-6">
                            [@ve.MaSuatChieuNavigation.MaPhimNavigation.PhanLoaiDoTuoi]
                        </small>
                    </div>
                    <div class="divider"></div>
                    <div class="row small">
                        <div class="col-6">
                            <div class="text-muted">Ngày chiếu</div>
                            <div class="fw-bold">
                                @ve.MaSuatChieuNavigation.ThoiGianBatDau.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted">Giờ chiếu</div>
                            <div class="fw-bold">
                                @ve.MaSuatChieuNavigation.ThoiGianBatDau.ToString("HH:mm")
                                — @ve.MaSuatChieuNavigation.ThoiGianKetThuc.ToString("HH:mm")
                            </div>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="text-muted">Phòng chiếu</div>
                            <div class="fw-bold">
                                @ve.MaSuatChieuNavigation.MaPhongNavigation.TenPhong
                            </div>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="text-muted">Ghế</div>
                            <div class="fw-bold fs-5">
                                @(ve.MaGheNavigation.TenHang + ve.MaGheNavigation.SoThu)
                                — @ve.MaGheNavigation.MaLoaiGheNavigation.TenLoaiGhe
                            </div>
                        </div>
                    </div>
                    <div class="divider"></div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="text-muted small">Mã vé</div>
                            <div class="fw-semibold small font-monospace">@ve.MaVe</div>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small">Giá vé</div>
                            <div class="fw-bold text-danger">@ve.GiaVe.ToString("N0") ₫</div>
                        </div>
                    </div>
                </div>
                <div class="qr-area">
                    @if (!string.IsNullOrEmpty(ve.MaQr))
                    {
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=@ve.MaQr"
                             alt="QR" width="100" />
                        <div class="small text-muted font-monospace mt-1">@ve.MaQr</div>
                    }
                </div>
            </div>
        }

       
        <div class="invoice">
            <div class="text-center mb-2">
                <div class="fw-bold fs-6">HÓA ĐƠN BÁN HÀNG</div>
                <div class="small text-muted">Rạp Chiếu Phim — Nhóm 1</div>
            </div>
            <div class="divider"></div>

            <div class="row small mb-2">
                <div class="col-6">
                    <span class="text-muted">Mã đơn:</span>
                    <span class="fw-semibold font-monospace"> @Model.MaDonHang</span>
                </div>
                <div class="col-6 text-end">
                    <span class="text-muted">Ngày:</span>
                    <span> @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                @if (Model.MaNhanVienNavigation != null)
                {
                    <div class="col-12 mt-1">
                        <span class="text-muted">Nhân viên:</span>
                        <span class="fw-semibold"> @Model.MaNhanVienNavigation.HoTen</span>
                    </div>
                }
            </div>

            <div class="divider"></div>

            <table class="table table-sm small mb-1">
                <thead>
                    <tr class="table-light">
                        <th>Phim / Ghế</th>
                        <th class="text-end">Giá vé</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ve in Model.ChiTietVe)
                    {
                        <tr>
                            <td>
                                @ve.MaSuatChieuNavigation.MaPhimNavigation.TenPhim
                                <small class="text-muted d-block">
                                    @ve.MaSuatChieuNavigation.ThoiGianBatDau.ToString("HH:mm dd/MM")
                                    — @ve.MaSuatChieuNavigation.MaPhongNavigation.TenPhong
                                    — Ghế @(ve.MaGheNavigation.TenHang + ve.MaGheNavigation.SoThu)
                                </small>
                            </td>
                            <td class="text-end fw-semibold">@ve.GiaVe.ToString("N0") ₫</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="divider"></div>

            <div class="d-flex justify-content-between small">
                <span class="text-muted">Tổng tiền:</span>
                <span>@Model.TongTienBanDau.ToString("N0") ₫</span>
            </div>
            <div class="d-flex justify-content-between fw-bold">
                <span>TỔNG CỘNG:</span>
                <span class="text-danger">@Model.TongTienSauGiam.ToString("N0") ₫</span>
            </div>
            <div class="d-flex justify-content-between small text-muted">
                <span>Thanh toán:</span>
                <span>@(tt?.PhuongThuc ?? "—")</span>
            </div>

            <div class="text-center mt-3 small text-muted">
                Cảm ơn quý khách! Chúc xem phim vui vẻ 🎬
            </div>
        </div>
    </div>

    <script>
        // Tự động mở hộp thoại in sau 500ms
        window.onload = function () {
            setTimeout(function () { window.print(); }, 500);
        };
    </script>
</body>
</html>