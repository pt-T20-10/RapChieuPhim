@model List<RapChieuPhim.Models.Entities.Phim>
@{
    ViewData["Title"] = "Bán vé — Chọn phim";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-ticket-detailed me-2 text-primary"></i>Chọn phim
    </h4>
    <a asp-action="Index" asp-area="RapPhim" asp-controller="BanHang"
       class="btn btn-outline-secondary btn-sm">
        ← Quay lại
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">Hiện không có phim nào đang chiếu.</div>
}
else
{
    <div class="row g-3">
        @foreach (var phim in Model)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-action="ChonGhe"
                   asp-route-maPhim="@phim.MaPhim"
                   class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm hover-card">
                        <img src="@(phim.DuongDanAnh ?? "/images/default/no-poster.jpg")"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;"
                             onerror="this.src='/images/default/no-poster.jpg'">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-1 text-dark">@phim.TenPhim</h6>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">
                                    @phim.MaTheLoaiNavigation?.TenTheLoai
                                </small>
                                <span class="badge bg-warning text-dark">
                                    @phim.PhanLoaiDoTuoi
                                </span>
                            </div>
                            <small class="text-muted">
                                @phim.ThoiLuong phút
                            </small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

<style>
    .hover-card {
        transition: .2s;
        cursor: pointer;
    }

        .hover-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,.12) !important;
        }
</style>