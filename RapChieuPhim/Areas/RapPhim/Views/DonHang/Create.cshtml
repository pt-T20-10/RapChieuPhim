@model RapChieuPhim.Models.Entities.DonHang

@{
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create</title>
</head>
<body>

<h4>DonHang</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="MaDonHang" class="control-label"></label>
                <input asp-for="MaDonHang" class="form-control" />
                <span asp-validation-for="MaDonHang" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaKhachHang" class="control-label"></label>
                <select asp-for="MaKhachHang" class ="form-control" asp-items="ViewBag.MaKhachHang"></select>
            </div>
            <div class="form-group">
                <label asp-for="MaNhanVien" class="control-label"></label>
                <select asp-for="MaNhanVien" class ="form-control" asp-items="ViewBag.MaNhanVien"></select>
            </div>
            <div class="form-group">
                <label asp-for="MaKhuyenMai" class="control-label"></label>
                <select asp-for="MaKhuyenMai" class ="form-control" asp-items="ViewBag.MaKhuyenMai"></select>
            </div>
            <div class="form-group">
                <label asp-for="TongTienBanDau" class="control-label"></label>
                <input asp-for="TongTienBanDau" class="form-control" />
                <span asp-validation-for="TongTienBanDau" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TongTienSauGiam" class="control-label"></label>
                <input asp-for="TongTienSauGiam" class="form-control" />
                <span asp-validation-for="TongTienSauGiam" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="DaXoa" /> @Html.DisplayNameFor(model => model.DaXoa)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</body>
</html>

