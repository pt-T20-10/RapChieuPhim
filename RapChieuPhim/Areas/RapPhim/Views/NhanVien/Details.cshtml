@model RapChieuPhim.Models.Entities.NhanVien

@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>📄 Chi tiết nhân viên</h2>
    <hr />

    <!-- ALERT -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow p-4">

        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Mã nhân viên:</strong> @Model.MaNhanVien
            </div>
            <div class="col-md-6">
                <strong>Họ tên:</strong> @Model.HoTen
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Ngày sinh:</strong>
                @(Model.NgaySinh?.ToString("dd/MM/yyyy"))
            </div>

            <div class="col-md-6">
                <strong>Giới tính:</strong>
                <span class="badge bg-info">
                    @Model.GioiTinh
                </span>
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Địa chỉ:</strong> @Model.DiaChi
            </div>

            <div class="col-md-6">
                <strong>Ngày vào làm:</strong>
                @Model.NgayVaoLam.ToString("dd/MM/yyyy")
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Ca làm việc:</strong>
                <span class="badge bg-secondary">
                    @Model.CaLamViec
                </span>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Edit"
               asp-route-id="@Model.MaNhanVien"
               class="btn btn-warning">
                ✏️ Sửa
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                ⬅️ Quay lại
            </a>
        </div>

    </div>
</div>