@model IEnumerable<RapChieuPhim.Models.Entities.NhanVien>

@{
    ViewData["Title"] = "Quản lý nhân viên";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2 class="mb-4">👨‍💼 Quản lý Nhân Viên</h2>

    <!-- ALERT -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3 d-flex justify-content-between">
        <a asp-action="Create" class="btn btn-primary">➕ Thêm nhân viên</a>

        <a asp-action="ExportExcel" class="btn btn-success">
            📤 Xuất Excel
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã</th>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Giới tính</th>
                    <th>Địa chỉ</th>
                    <th>Ngày vào làm</th>
                    <th>Ca làm</th>
                    <th>Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Where(x => !x.DaXoa))
                {
                    <tr>
                        <td>@item.MaNhanVien</td>

                        <td>
                            <strong>@item.HoTen</strong>
                        </td>

                        <td>
                            @(item.NgaySinh?.ToString("dd/MM/yyyy"))
                        </td>

                        <td>
                            <span class="badge bg-info">
                                @item.GioiTinh
                            </span>
                        </td>

                        <td>@item.DiaChi</td>

                        <td>
                            @item.NgayVaoLam.ToString("dd/MM/yyyy")
                        </td>

                        <td>
                            <span class="badge bg-secondary">
                                @item.CaLamViec
                            </span>
                        </td>

                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@item.MaNhanVien"
                               class="btn btn-sm btn-warning">
                                Sửa
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.MaNhanVien"
                               class="btn btn-sm btn-info">
                                Chi tiết
                            </a>

                            <a href="#"
                               class="btn btn-sm btn-danger"
                               onclick="confirmDelete('@item.MaNhanVien')">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- FORM DELETE -->
<form id="deleteForm" method="post" asp-action="Delete">
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    function confirmDelete(id) {
        if (confirm("Bạn có chắc muốn xóa nhân viên này không?")) {
            document.getElementById("deleteId").value = id;
            document.getElementById("deleteForm").submit();
        }
    }
</script>