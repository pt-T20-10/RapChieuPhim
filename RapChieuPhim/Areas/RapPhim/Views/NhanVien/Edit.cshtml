@model RapChieuPhim.Models.Entities.NhanVien

@{
    ViewData["Title"] = "Sửa nhân viên";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>✏️ Sửa nhân viên</h2>
    <hr />

    <!-- ALERT -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Edit" class="card p-4 shadow">

        <!-- Validation summary -->
        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        <input type="hidden" asp-for="MaNhanVien" />

        <div class="row">

            <div class="col-md-6">
                <label>Mã nhân viên</label>
                <input asp-for="MaNhanVien" class="form-control" readonly />
            </div>

            <div class="col-md-6">
                <label>Họ tên</label>
                <input asp-for="HoTen" class="form-control" placeholder="VD: Nguyễn Văn A" />
                <span asp-validation-for="HoTen" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Ngày sinh</label>
                <input asp-for="NgaySinh" type="date" class="form-control" />
                <span asp-validation-for="NgaySinh" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Giới tính</label>
                <select asp-for="GioiTinh" class="form-select">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam">Nam</option>
                    <option value="Nữ">Nữ</option>
                </select>
                <span asp-validation-for="GioiTinh" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Địa chỉ</label>
                <input asp-for="DiaChi" class="form-control" placeholder="VD: TP.HCM" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Ngày vào làm</label>
                <input asp-for="NgayVaoLam" type="date" class="form-control" />
                <span asp-validation-for="NgayVaoLam" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Ca làm việc</label>
                <input asp-for="CaLamViec" class="form-control" placeholder="VD: Ca sáng / Ca tối" />
            </div>

        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}