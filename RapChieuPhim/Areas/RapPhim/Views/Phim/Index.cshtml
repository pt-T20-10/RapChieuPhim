@model IEnumerable<RapChieuPhim.Models.Entities.Phim>

@{
    ViewData["Title"] = "Quản lý Phim";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2 class="mb-4">🎬 Quản lý Phim</h2>

    <!-- ALERT -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3 d-flex justify-content-between">
        <a asp-action="Create" class="btn btn-primary">➕ Thêm phim</a>

        <a href="#" class="btn btn-success" onclick="exportExcel()">📤 Xuất Excel</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Tên phim</th>
                    <th>Thời lượng</th>
                    <th>Ngày phát hành</th>
                    <th>Thể loại</th>
                    <th>Trạng thái</th>
                    <th>Ảnh</th>
                    <th>Trailer</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenPhim</td>
                        <td>@item.ThoiLuong phút</td>
                        <td>@item.NgayPhatHanh</td>
                        <td>@item.MaTheLoaiNavigation?.TenTheLoai</td>

                        <td>
                            <span class="badge bg-info">@item.TrangThai</span>
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(item.DuongDanAnh))
                            {
                                <img src="@item.DuongDanAnh" width="60" />
                            }
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(item.DuongDanTrailer))
                            {
                                <a href="@item.DuongDanTrailer" target="_blank">Xem</a>
                            }
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.MaPhim" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaPhim" class="btn btn-sm btn-info">Chi tiết</a>

                            <!-- XÓA MỀM -->
                            <a href="#"
                               class="btn btn-sm btn-danger"
                               onclick="confirmDelete('@item.MaPhim')">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- FORM DELETE -->
<form id="deleteForm" method="post" asp-action="Delete">
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    function confirmDelete(id) {
        if (confirm("Bạn có chắc muốn xóa phim này không?")) {
            document.getElementById("deleteId").value = id;
            document.getElementById("deleteForm").submit();
        }
    }

    function exportExcel() {
        alert("Đang xuất Excel...");
        window.location.href = '/RapPhim/Phim/ExportExcel';
    }
</script>