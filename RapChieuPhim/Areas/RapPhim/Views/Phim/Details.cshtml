@model RapChieuPhim.Models.Entities.Phim

@{
    ViewData["Title"] = "Chi tiết phim";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">🎬 Chi tiết phim</h4>
        </div>

        <div class="card-body">
            <div class="row">

                <!-- ẢNH -->
                <div class="col-md-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.DuongDanAnh))
                    {
                        <img src="@Model.DuongDanAnh" class="img-fluid rounded shadow" />
                    }
                    else
                    {
                        <p class="text-muted">Không có ảnh</p>
                    }
                </div>

                <!-- THÔNG TIN -->
                <div class="col-md-8">
                    <table class="table table-bordered">
                        <tr>
                            <th>Tên phim</th>
                            <td>@Model.TenPhim</td>
                        </tr>
                        <tr>
                            <th>Thể loại</th>
                            <td>@Model.MaTheLoaiNavigation?.TenTheLoai</td>
                        </tr>
                        <tr>
                            <th>Thời lượng</th>
                            <td>@Model.ThoiLuong phút</td>
                        </tr>
                        <tr>
                            <th>Ngày phát hành</th>
                            <td>@Model.NgayPhatHanh</td>
                        </tr>
                        <tr>
                            <th>Phân loại độ tuổi</th>
                            <td>@Model.PhanLoaiDoTuoi</td>
                        </tr>
                        <tr>
                            <th>Trạng thái</th>
                            <td>
                                <span class="badge bg-info">@Model.TrangThai</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Mô tả</th>
                            <td>@Model.MoTa</td>
                        </tr>
                        <tr>
                            <th>Đã xoá</th>
                            <td>@Model.DaXoa</td>
                        </tr>
                    </table>

                    <!-- TRAILER -->
                    @if (!string.IsNullOrEmpty(Model.DuongDanTrailer))
                    {
                        <div class="mt-3">
                            <h5>🎥 Trailer</h5>
                            <a href="@Model.DuongDanTrailer" target="_blank" class="btn btn-danger">
                                Xem trailer
                            </a>
                        </div>
                    }
                </div>

            </div>
        </div>

        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model.MaPhim" class="btn btn-warning">
                ✏️ Sửa
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                ← Quay lại
            </a>
        </div>
    </div>

</div>