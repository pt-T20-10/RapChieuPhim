@model RapChieuPhim.Models.Entities.Phim

@{
    ViewData["Title"] = "Chỉnh sửa phim";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>✏️ Chỉnh sửa phim</h2>
    <hr />

    <form asp-action="Edit" class="card p-4 shadow">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- Hidden key -->
        <input type="hidden" asp-for="MaPhim" />

        <div class="row">

            <div class="col-md-6">
                <label>Mã phim</label>
                <input asp-for="MaPhim" class="form-control" readonly />
            </div>

            <div class="col-md-6">
                <label>Tên phim</label>
                <input asp-for="TenPhim" class="form-control" />
                <span asp-validation-for="TenPhim" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Thể loại</label>
                <select asp-for="MaTheLoai" class="form-select" asp-items="ViewBag.MaTheLoai"></select>
                <span asp-validation-for="MaTheLoai" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Thời lượng</label>
                <input asp-for="ThoiLuong" class="form-control" />
                <span asp-validation-for="ThoiLuong" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Ngày phát hành</label>
                <input asp-for="NgayPhatHanh" class="form-control" type="date" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Trạng thái</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="SapChieu">Sắp chiếu</option>
                    <option value="DangChieu">Đang chiếu</option>
                    <option value="NgungChieu">Ngừng chiếu</option>
                </select>
            </div>

            <div class="col-md-6 mt-2">
                <label>Mô tả</label>
                <input asp-for="MoTa" class="form-control" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Phân loại</label>
                <input asp-for="PhanLoaiDoTuoi" class="form-control" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Ảnh</label>
                <input asp-for="DuongDanAnh" class="form-control" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Trailer</label>
                <input asp-for="DuongDanTrailer" class="form-control" />
            </div>

            <div class="col-md-6 mt-2 form-check">
                <input class="form-check-input" asp-for="DaXoa" />
                <label class="form-check-label">
                    Đã xóa
                </label>
            </div>

        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}