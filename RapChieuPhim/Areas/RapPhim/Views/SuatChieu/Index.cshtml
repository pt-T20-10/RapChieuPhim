@model IEnumerable<RapChieuPhim.Models.Entities.SuatChieu>

@{
    ViewData["Title"] = "Quản lý Suất Chiếu";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2 class="mb-4">🎟️ Quản lý Suất Chiếu</h2>

    <!-- ALERT -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3 d-flex justify-content-between">
        <a asp-action="Create" class="btn btn-primary">➕ Thêm suất chiếu</a>
        <a asp-action="ExportExcel" class="btn btn-success">📤 Xuất Excel</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã</th>
                    <th>Phim</th>
                    <th>Phòng</th>
                    <th>Bắt đầu</th>
                    <th>Kết thúc</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaSuatChieu</td>
                        <td>@item.MaPhimNavigation?.TenPhim</td>
                        <td>@item.MaPhongNavigation?.TenPhong</td>
                        <td>@item.ThoiGianBatDau</td>
                        <td>@item.ThoiGianKetThuc</td>
                        <td>@item.GiaGoc</td>

                        <td>
                            <span class="badge bg-info">@item.TrangThai</span>
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.MaSuatChieu" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaSuatChieu" class="btn btn-sm btn-info">Chi tiết</a>

                            <!-- Xóa mềm -->
                            <a href="#" class="btn btn-sm btn-danger"
                               onclick="confirmDelete('@item.MaSuatChieu')">
                                Xóa
                            </a>

                            <!-- Hủy suất chiếu -->
                            @if (item.TrangThai != "DaHuy")
                            {
                                <a asp-action="Cancel" asp-route-id="@item.MaSuatChieu"
                                   class="btn btn-sm btn-secondary">
                                    Hủy
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="deleteForm" method="post" asp-action="Delete">
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    function confirmDelete(id) {
        if (confirm("Bạn có chắc muốn xóa suất chiếu này không?")) {
            document.getElementById("deleteId").value = id;
            document.getElementById("deleteForm").submit();
        }
    }
</script>