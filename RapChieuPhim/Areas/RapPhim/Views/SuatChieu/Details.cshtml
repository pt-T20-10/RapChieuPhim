@model RapChieuPhim.Models.Entities.SuatChieu

@{
    ViewData["Title"] = "Chi tiết suất chiếu";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>📄 Chi tiết suất chiếu</h2>
    <hr />

    <div class="card p-4 shadow">

        <div class="row">

            <div class="col-md-6">
                <p><strong>Mã:</strong> @Model.MaSuatChieu</p>
            </div>

            <div class="col-md-6">
                <p><strong>Phim:</strong> @Model.MaPhimNavigation?.TenPhim</p>
            </div>

            <div class="col-md-6">
                <p><strong>Phòng:</strong> @Model.MaPhongNavigation?.TenPhong</p>
            </div>

            <div class="col-md-6">
                <p><strong>Bắt đầu:</strong> @Model.ThoiGianBatDau</p>
            </div>

            <div class="col-md-6">
                <p><strong>Kết thúc:</strong> @Model.ThoiGianKetThuc</p>
            </div>

            <div class="col-md-6">
                <p><strong>Giá:</strong> @Model.GiaGoc</p>
            </div>

            <div class="col-md-6">
                <p>
                    <strong>Trạng thái:</strong>
                    <span class="badge bg-info">@Model.TrangThai</span>
                </p>
            </div>

        </div>

        <a asp-action="Index" class="btn btn-secondary mt-3">Quay lại</a>

    </div>
</div>