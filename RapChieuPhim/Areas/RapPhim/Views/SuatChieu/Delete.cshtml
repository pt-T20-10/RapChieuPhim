@model RapChieuPhim.Models.Entities.SuatChieu
@{
    ViewData["Title"] = "Xóa Suất chiếu";
    bool coVe = ViewBag.CoVe == true;
}

<div class="mb-3">
    <a asp-action="Index" asp-area="RapPhim" class="btn btn-outline-secondary">← Quay lại</a>
</div>

<div class="card shadow-sm" style="max-width:560px">
    <div class="card-header @(coVe ? "bg-warning" : "bg-danger") text-white">
        <h5 class="mb-0">@(coVe ? "⚠️ Không thể xóa suất chiếu này" : "🗑️ Xác nhận xóa suất chiếu")</h5>
    </div>
    <div class="card-body">

        <dl class="row mb-3">
            <dt class="col-sm-4">Mã suất chiếu</dt>
            <dd class="col-sm-8"><code>@Model.MaSuatChieu</code></dd>

            <dt class="col-sm-4">Phim</dt>
            <dd class="col-sm-8">@(Model.MaPhimNavigation?.TenPhim ?? Model.MaPhim)</dd>

            <dt class="col-sm-4">Phòng chiếu</dt>
            <dd class="col-sm-8">@(Model.MaPhongNavigation?.TenPhong ?? Model.MaPhong)</dd>

            <dt class="col-sm-4">Giờ bắt đầu</dt>
            <dd class="col-sm-8">@Model.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-4">Giờ kết thúc</dt>
            <dd class="col-sm-8">@Model.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-4">Trạng thái</dt>
            <dd class="col-sm-8">@Model.TrangThai</dd>
        </dl>

        @if (coVe)
        {
            <div class="alert alert-danger">
                <strong>🚫 Không thể xóa — dữ liệu đang được sử dụng trong hệ thống</strong>
                <p class="mb-0 mt-1 small">Suất chiếu đang có vé chưa sử dụng. Vui lòng hủy tất cả vé trước khi xóa.</p>
            </div>
            <a asp-action="Index" asp-area="RapPhim" class="btn btn-secondary">Quay lại danh sách</a>
        }
        else
        {
            <div class="alert alert-warning">
                <strong>⚠️ Bạn có chắc muốn xóa bản ghi này không?</strong>
                <p class="mb-0 mt-1 small">Suất chiếu sẽ bị hủy và ẩn khỏi hệ thống.</p>
            </div>
            <form asp-action="Delete" asp-area="RapPhim" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="MaSuatChieu" />
                <button type="submit" class="btn btn-danger">🗑️ Đồng ý, xóa</button>
                <a asp-action="Index" asp-area="RapPhim" class="btn btn-outline-secondary ms-2">Hủy, quay lại</a>
            </form>
        }
    </div>
</div>
