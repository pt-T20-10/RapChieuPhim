@model RapChieuPhim.Models.Entities.SuatChieu

@{
    ViewData["Title"] = "Sửa suất chiếu";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    <h2>✏️ Sửa suất chiếu</h2>
    <hr />

    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="Edit" class="card p-4 shadow" id="formEdit">

        <div class="row">

            <div class="col-md-6">
                <label>Mã suất chiếu</label>
                <input asp-for="MaSuatChieu" class="form-control" readonly />
            </div>

            <div class="col-md-6">
                <label>Phim</label>
                <select asp-for="MaPhim" class="form-select" asp-items="ViewBag.MaPhim"></select>
                <span asp-validation-for="MaPhim" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Phòng chiếu</label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Thời gian bắt đầu</label>
                <input asp-for="ThoiGianBatDau" type="datetime-local" class="form-control" id="batdau" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Thời gian kết thúc</label>
                <input asp-for="ThoiGianKetThuc" type="datetime-local" class="form-control" id="ketthuc" />
                <span class="text-danger" id="errTime"></span>
            </div>

            <div class="col-md-6 mt-2">
                <label>Giá vé</label>
                <input asp-for="GiaGoc" class="form-control" />
            </div>

            <div class="col-md-6 mt-2">
                <label>Trạng thái</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="DaLenLich">Đã lên lịch</option>
                    <option value="DangChieu">Đang chiếu</option>
                    <option value="DaKetThuc">Đã kết thúc</option>
                    <option value="DaHuy">Đã hủy</option>
                </select>
            </div>

        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("formEdit").addEventListener("submit", function (e) {

            const batdau = new Date(document.getElementById("batdau").value);
            const ketthuc = new Date(document.getElementById("ketthuc").value);
            const err = document.getElementById("errTime");

            err.textContent = "";

            if (!document.getElementById("batdau").value || !document.getElementById("ketthuc").value) {
                err.textContent = "⚠ Vui lòng nhập đầy đủ thời gian";
                e.preventDefault();
                return;
            }

            if (ketthuc <= batdau) {
                err.textContent = "⚠ Thời gian kết thúc phải lớn hơn bắt đầu";
                e.preventDefault();
                return;
            }
        });
    </script>
}