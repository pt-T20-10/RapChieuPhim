@model RapChieuPhim.Models.ViewModels.VeViewModel
@{
    var ve = Model.Ve;
}

<div class="ticket-wrap mx-auto" style="max-width:360px; font-family:'Courier New',monospace;">
    <div class="card border shadow">

       
        <div class="text-center py-3 border-bottom bg-light">
            <div class="fw-bold fs-5 letter-spacing-2">VÉ XEM PHIM</div>
            <small class="text-muted">Rạp Chiếu Phim — Nhóm 1</small>
        </div>

        <div class="px-3 py-2 small">

            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                <div>
                    <div class="text-muted">Mã vé</div>
                    <div class="fw-bold">@ve.MaVe</div>
                </div>
                <div class="text-end">
                    <div class="text-muted">Trạng thái</div>
                    <div class="fw-bold text-@(ve.TrangThai == "ChuaSuDung" ? "success" : "secondary")">
                        @(ve.TrangThai == "ChuaSuDung" ? "Hợp lệ" :
                                                ve.TrangThai == "DaSuDung" ? "Đã sử dụng" : "Đã hủy")
                    </div>
                </div>
            </div>

            <div class="border-bottom pb-2 mb-2">
                <div class="fw-bold fs-6">@Model.TenPhim</div>
                <div class="text-muted">[@Model.PhanLoaiDoTuoi]</div>
            </div>

         
            <div class="border-bottom pb-2 mb-2">
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Ngày:</span>
                    <span>@Model.ThoiGianBatDau.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Giờ:</span>
                    <span>
                        @Model.ThoiGianBatDau.ToString("HH:mm")
                        – @Model.ThoiGianKetThuc.ToString("HH:mm")
                    </span>
                </div>
            </div>

         
            <div class="border-bottom pb-2 mb-2">
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Phòng:</span>
                    <span class="fw-semibold">@Model.TenPhong</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Ghế:</span>
                    <span class="fw-bold fs-6">@Model.Ghe — @Model.LoaiGhe</span>
                </div>
            </div>

          
            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                <span class="text-muted">Giá vé:</span>
                <span class="fw-bold">@ve.GiaVe.ToString("N0") ₫</span>
            </div>

        </div>

  
        <div class="text-center py-3 bg-light border-top"
             style="border-top-style:dashed !important;">
            @if (!string.IsNullOrEmpty(ve.MaQr))
            {
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=@ve.MaQr"
                     alt="QR" width="100" />
                <div class="mt-1 text-muted" style="font-size:10px;">@ve.MaQr</div>
            }
            else
            {
                <div class="text-muted small fst-italic">Chưa có mã QR</div>
            }
        </div>

    </div>
</div>